{% extends "base.html.twig" %}

{% block title %}{{ page.title|raw }}{% endblock %}
{% block description %}{% if page.meta_description is not null %}{{ page.meta_description|raw }}{% else %}{{ parent() }}{% endif %}{% endblock %}
{% block robots %}{% if page.meta_robots is not null %}{{ page.meta_robots|raw }}{% else %}{{ parent() }}{% endif %}{% endblock %}
{% block head_styles %}{% if page.head_styles is not null %}{{ page.head_styles|raw }}{% else %}{{ parent() }}{% endif %}{% endblock %}

{% block content %}
{% for blk in page.blocks %}{{ include('blocks/' ~ blk.type ~ '.html.twig', { blk: blk }, false)|trim|raw }}{{ loop.last ? "\n" : "\n\n" }}{% endfor %}
{% endblock %}
