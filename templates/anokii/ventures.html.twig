{% extends "anokii/_shell.html.twig" %}

{% block anokii_styles %}
  :root{
    --green:#138a55; --green-soft:#e4f7ee;
    --amber:#a96a00; --amber-soft:#fff3df;
    --grey:#5b6172; --grey-soft:#eef0f4;
    --cyan-soft:#e3f4f8;
    --card-shadow:0 1px 3px rgba(10,14,18,.05),0 8px 24px rgba(10,14,18,.06);
  }
  /* Cowork-style (the Identity Workspace template): the conversation is the
     central pane; the lanes are the work-surface rail on the right. */
  .cowork{display:flex;gap:0;align-items:flex-start}
  .cowork-chat{flex:1;min-width:0;position:sticky;top:74px;height:calc(100vh - 98px);display:flex;flex-direction:column;background:#fff;border:1px solid var(--line);border-radius:18px;box-shadow:var(--card-shadow);overflow:hidden}
  .cowork-main{flex:0 0 var(--rail-w,520px);width:var(--rail-w,520px);min-width:0}
  .cw-resizer{flex:0 0 26px;position:sticky;top:74px;height:calc(100vh - 98px);cursor:col-resize;touch-action:none}
  .cw-resizer::before{content:"";position:absolute;top:0;bottom:0;left:50%;transform:translateX(-50%);width:1px;background:var(--line)}
  .cw-resizer::after{content:"";position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:4px;height:40px;border-radius:3px;background:#cdd3dd;transition:background .15s,height .15s}
  .cw-resizer:hover::after,.cw-resizer.drag::after{background:var(--cyan2);height:64px}
  @media(max-width:1180px){
    .cowork{flex-direction:column}
    .cowork-chat{position:static;flex:none;height:600px;max-height:74vh}
    .cowork-main{flex:none;width:auto}
    .cw-resizer{display:none}
  }
  /* placeholder-grade banner: always visible, deliberately loud */
  .vn-banner{background:#fff8ec;border:1px solid #ecd9b0;border-left:4px solid var(--amber);border-radius:12px;padding:13px 16px;margin-bottom:22px;font-size:13.5px;line-height:1.55;color:#5a4a26}
  .vn-banner b{color:var(--amber);font-family:"Oswald",sans-serif;text-transform:uppercase;letter-spacing:.08em;font-size:12px}
  /* roll-up card */
  .vn-roll{background:#fff;border:1px solid var(--line);border-radius:14px;padding:18px 20px;margin-bottom:24px;box-shadow:var(--card-shadow)}
  .vn-roll h2{font-size:11.5px;text-transform:uppercase;letter-spacing:.14em;color:var(--muted);margin:0 0 11px;font-weight:600;font-family:"Oswald",sans-serif}
  .vn-share{font-size:13px;color:var(--muted);margin:9px 0 0;font-family:"Oswald",sans-serif}
  .vn-share b{color:var(--ink)}
  /* numeric tables (roll-up + lane grids) */
  table.vt{width:100%;border-collapse:collapse;font-size:13.5px}
  table.vt th{font-family:"Oswald",sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);text-align:right;padding:5px 8px;border-bottom:1px solid var(--line)}
  table.vt th:first-child{text-align:left}
  table.vt td{padding:6px 8px;border-bottom:1px solid #f0f2f5;text-align:right;font-variant-numeric:tabular-nums;color:var(--ink)}
  table.vt td:first-child{text-align:left;font-family:"Oswald",sans-serif;font-size:12px;letter-spacing:.04em;color:var(--muted);text-transform:uppercase}
  table.vt tr:last-child td{border-bottom:none}
  table.vt input{width:88px;box-sizing:border-box;text-align:right;font:inherit;font-variant-numeric:tabular-nums;color:var(--ink);border:1px solid transparent;border-radius:7px;padding:3px 6px;background:transparent}
  table.vt input:hover{border-color:var(--line);background:var(--bg)}
  table.vt input:focus{outline:none;border-color:var(--cyan);background:#fff;box-shadow:0 0 0 3px rgba(31,182,214,.14)}
  table.vt input.dirty{border-color:var(--amber);background:var(--amber-soft)}
  /* sections + lane cards */
  .grid{display:grid;grid-template-columns:1fr;gap:14px;align-items:start;margin-top:4px}
  .card{background:#fff;border:1px solid var(--line);border-radius:14px;padding:18px;display:flex;flex-direction:column;gap:12px;box-shadow:var(--card-shadow);scroll-margin-top:84px;transition:box-shadow .2s,border-color .2s}
  .card-top{display:flex;justify-content:space-between;align-items:center;gap:10px}
  .card h4{margin:0;font-family:"Oswald",sans-serif;font-weight:600;font-size:16.5px;color:var(--ink);letter-spacing:.01em}
  .card .sum{font-size:13.5px;color:var(--muted);line-height:1.5;margin:-6px 0 0}
  .vn-save{font-family:"Oswald",sans-serif;font-size:12.5px;font-weight:600;letter-spacing:.03em;color:#fff;background:var(--cyan2);border:none;border-radius:8px;padding:6px 14px;cursor:pointer;flex:0 0 auto}
  .vn-save:hover{filter:brightness(1.05)}
  .vn-save:disabled{opacity:.4;cursor:default}
  /* assumptions */
  .vn-ass h5{margin:0 0 5px;font-family:"Oswald",sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted)}
  .vn-ass ul{margin:0;padding:0 0 0 17px;display:flex;flex-direction:column;gap:4px}
  .vn-ass li{font-size:13.5px;line-height:1.5;color:var(--ink)}
  .vn-ass textarea{width:100%;box-sizing:border-box;font-family:inherit;font-size:13.5px;line-height:1.5;color:var(--ink);border:1px solid var(--line);border-radius:9px;padding:8px 10px;background:var(--bg);resize:vertical}
  .vn-ass textarea:focus{outline:none;border-color:var(--cyan);box-shadow:0 0 0 3px rgba(31,182,214,.16)}
  .vn-edit{font-family:"Oswald",sans-serif;font-size:12px;font-weight:600;letter-spacing:.04em;color:var(--cyan2);background:none;border:none;cursor:pointer;padding:2px 4px}
  .vn-edit:hover{text-decoration:underline}
  /* gating facts */
  .vn-facts h5{margin:0 0 7px;font-family:"Oswald",sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted)}
  .fact{display:flex;flex-direction:column;gap:3px;border:1px dashed var(--line);border-radius:10px;padding:9px 11px;margin-bottom:7px}
  .fact-top{display:flex;align-items:center;gap:9px}
  .fact-top b{font-family:"Oswald",sans-serif;font-weight:600;font-size:13.5px;color:var(--ink)}
  .fstat{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;border-radius:20px;padding:3px 10px;font-family:"Oswald",sans-serif;flex:0 0 auto}
  .f-placeholder{background:var(--amber-soft);color:var(--amber)}
  .f-confirmed{background:var(--green-soft);color:var(--green)}
  .fact .fd{font-size:13px;color:var(--muted);line-height:1.5}
  .fact .fby{font-size:12px;color:var(--green);font-family:"Oswald",sans-serif;letter-spacing:.02em;min-height:0}
  .fact-act{display:flex;gap:8px;align-items:center;margin-top:2px}
  .fbtn{font-family:"Oswald",sans-serif;font-size:11.5px;font-weight:600;letter-spacing:.04em;color:var(--cyan2);background:#fff;border:1px solid var(--line);border-radius:7px;padding:3px 10px;cursor:pointer}
  .fbtn:hover{background:var(--cyan-soft);border-color:#cdeaf1}
  .fbtn:disabled{opacity:.5;cursor:default}
  /* card footer + history (Identity pattern) */
  .cfoot{display:flex;justify-content:space-between;align-items:center;gap:10px;border-top:1px solid var(--line);padding-top:10px;margin-top:1px}
  .edited{font-size:12px;color:var(--muted);font-family:"Oswald",sans-serif;letter-spacing:.02em;min-height:15px}
  .saveflash{color:var(--cyan2)}
  .hbtn{font-family:"Oswald",sans-serif;font-size:12px;font-weight:600;letter-spacing:.04em;color:var(--cyan2);background:none;border:none;cursor:pointer;padding:2px 4px;flex:0 0 auto}
  .hbtn:hover{text-decoration:underline}
  .hist{display:none;border-top:1px dashed var(--line);padding-top:10px;margin-top:2px}
  .hist.open{display:block}
  .hist ol{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:9px}
  .hist li{display:flex;gap:10px;font-size:13px;line-height:1.45}
  .hist .stat{flex:0 0 auto;width:8px;height:8px;border-radius:2px;margin-top:5px;background:var(--cyan2)}
  .hist .meta{color:var(--muted);font-family:"Oswald",sans-serif;font-size:11.5px;letter-spacing:.02em}
  .hist .sum{color:var(--ink)}
  .hist .cur{color:var(--cyan2);font-weight:700}
  .hist .empty{color:var(--muted);font-size:13px}
  /* live draft preview on a lane card (Co-Intelligence proposes here) */
  .card.previewing{border-color:var(--cyan);box-shadow:0 0 0 3px rgba(31,182,214,.18),var(--card-shadow)}
  .lane-draft{border:1px dashed var(--cyan);background:#f2fafd;border-radius:11px;overflow:hidden}
  .lane-draft .pd-h{font-family:"Oswald",sans-serif;font-size:11px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--cyan2);padding:8px 12px;border-bottom:1px solid #d7ecf3;display:flex;align-items:center;gap:7px}
  .lane-draft.danger{border-color:#d98b5f;background:#fdf3ec} .lane-draft.danger .pd-h{color:#c4631f;border-bottom-color:#f0d6c4}
  .lane-draft .pd-body{padding:10px 12px;display:flex;flex-direction:column;gap:8px}
  .pd-row{display:flex;flex-wrap:wrap;align-items:baseline;gap:8px;font-size:13.5px;color:var(--ink)}
  .pd-row .f{font-family:"Oswald",sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--muted);min-width:88px}
  .pd-was{color:#9a4242;text-decoration:line-through;opacity:.8;overflow-wrap:anywhere}
  .pd-new{color:#138a55;font-weight:600;overflow-wrap:anywhere}
  .pd-act{display:flex;gap:8px;padding:0 12px 11px}
  .cw-point{color:var(--cyan2);font-size:13.5px;margin:6px 0 0}
  /* Co-Intelligence pane (shared look with the Identity companion) */
  .cw-head{display:flex;align-items:center;gap:11px;padding:14px 16px;border-bottom:1px solid var(--line);background:linear-gradient(180deg,#f7fbfc,#fff)}
  .cw-ava{flex:0 0 auto;width:34px;height:34px;border-radius:10px;background:var(--cyan2);color:#fff;display:flex;align-items:center;justify-content:center;font-family:"Anton",sans-serif;font-size:15px;letter-spacing:.02em}
  .cw-head b{font-family:"Oswald",sans-serif;font-weight:600;font-size:15px;color:var(--ink);display:block;line-height:1.2}
  .cw-head small{font-size:12px;color:var(--muted);display:flex;align-items:center;gap:6px}
  .cw-head small::before{content:"";width:7px;height:7px;border-radius:50%;background:var(--green)}
  .cw-new{margin-left:auto;flex:0 0 auto;font-family:"Oswald",sans-serif;font-size:12px;font-weight:600;letter-spacing:.02em;color:var(--cyan2);background:#fff;border:1px solid var(--line);border-radius:8px;padding:5px 11px;cursor:pointer}
  .cw-new:hover{background:var(--cyan-soft);border-color:#cdeaf1}
  .cw-stream{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:13px;background:var(--bg)}
  .imsg{display:flex;gap:9px;align-items:flex-start}
  .imsg .av{flex:0 0 auto;width:26px;height:26px;border-radius:8px;font-family:"Oswald",sans-serif;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;color:#fff}
  .imsg.user{flex-direction:row-reverse}
  .imsg.user .av{background:var(--ink)} .imsg.ai .av{background:var(--cyan2)}
  .ibub{background:#fff;border:1px solid var(--line);border-radius:13px;padding:10px 13px;font-size:14.5px;line-height:1.58;color:var(--ink);max-width:86%;overflow-wrap:anywhere;box-shadow:0 1px 2px rgba(10,14,18,.04)}
  .imsg.user .ibub{background:#0a0e12;border-color:#0a0e12;color:#eaf6f9}
  .ibub p{margin:0 0 7px} .ibub p:last-child{margin:0} .ibub strong{font-weight:700}
  .cw-chips{display:flex;flex-wrap:wrap;gap:7px;margin:2px 0 0 35px}
  .cw-chip{font-size:12.5px;background:#fff;border:1px solid var(--line);border-radius:20px;padding:6px 12px;color:var(--cyan2);cursor:pointer;font-family:"Oswald",sans-serif;letter-spacing:.01em}
  .cw-chip:hover{background:var(--cyan-soft);border-color:#cdeaf1}
  .cw-foot{border-top:1px solid var(--line);padding:11px;display:flex;gap:8px;align-items:flex-end;background:#fff}
  .cw-foot textarea{flex:1;border:1px solid var(--line);border-radius:11px;padding:10px 12px;font:inherit;font-size:14.5px;line-height:1.5;resize:none;height:42px;max-height:140px;color:var(--ink);background:var(--bg)}
  .cw-foot textarea:focus{outline:none;border-color:var(--cyan);box-shadow:0 0 0 3px rgba(31,182,214,.14);background:#fff}
  .cw-send{flex:0 0 auto;background:var(--cyan2);color:#fff;border:none;border-radius:11px;height:42px;padding:0 16px;font-family:"Oswald",sans-serif;font-weight:600;font-size:14px;cursor:pointer}
  .cw-send:hover{background:#0f6f85} .cw-send:disabled{opacity:.5;cursor:default}
  .iwork{display:inline-flex;align-items:center;gap:7px;color:var(--muted);font-size:13.5px}
  .iwork .d{width:6px;height:6px;border-radius:50%;background:var(--cyan2);animation:ipulse 1s infinite}
  @keyframes ipulse{0%,100%{opacity:.3}50%{opacity:1}}
  /* proposal card inside the conversation */
  .iprop{margin-top:9px;border:1px solid var(--cyan);border-radius:11px;background:#f2fafd;overflow:hidden}
  .iprop.danger{border-color:#d98b5f;background:#fdf3ec}
  .iprop .ph{font-family:"Oswald",sans-serif;font-size:11px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--cyan2);padding:8px 12px;border-bottom:1px solid #d7ecf3}
  .iprop.danger .ph{color:#c4631f}
  .iprop .ps{padding:9px 12px 4px;font-weight:600;font-size:14px;color:var(--ink)}
  .iprop ul.pd{list-style:none;margin:0;padding:4px 12px 8px;display:flex;flex-direction:column;gap:5px}
  .iprop ul.pd li{font-size:13px;line-height:1.45;display:flex;flex-wrap:wrap;gap:6px;align-items:baseline}
  .iprop .f{font-family:"Oswald",sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--muted);min-width:74px}
  .iprop .b{color:#9a4242;text-decoration:line-through;opacity:.85;overflow-wrap:anywhere} .iprop .a{color:#138a55;font-weight:600;overflow-wrap:anywhere}
  .iprop .pact{display:flex;gap:8px;padding:8px 12px 11px}
  .ipb{font-family:"Oswald",sans-serif;font-size:13px;font-weight:600;border-radius:9px;padding:6px 16px;cursor:pointer;border:1px solid transparent}
  .ipb.ok{background:var(--cyan);color:#06303a} .ipb.no{background:#fff;color:#5b6172;border-color:var(--line)} .ipb:disabled{opacity:.5;cursor:default}
{% endblock %}

{% block anokii_content %}
<div class="cowork">
  <aside class="cowork-chat" aria-label="Co-Intelligence assistant">
    <div class="cw-head">
      <div class="cw-ava">CI</div>
      <div><b>Co-Intelligence</b><small>Working on the venture numbers with you</small></div>
      <button type="button" class="cw-new" id="cwNew" title="Start a new chat">New chat</button>
    </div>
    <div class="cw-stream" id="cwStream">
      <div class="imsg ai" id="cwIntro"><div class="av">CI</div><div class="ibub">Aanii. I can read the venture lanes with you and draft number or assumption changes. Everything here is placeholder-grade until confirmed. When I draft an edit, it appears on the lane card for you to approve before anything is written.</div></div>
      <div class="cw-chips" id="cwChips">
        <button type="button" class="cw-chip">What is the likely Yr 5 roll-up?</button>
        <button type="button" class="cw-chip">Read the Faraday lane</button>
        <button type="button" class="cw-chip">Which gating facts are still placeholders?</button>
      </div>
    </div>
    <div class="cw-foot">
      <textarea id="cwInput" rows="1" placeholder="Ask about a lane, or tell me what to change..."></textarea>
      <button type="button" class="cw-send" id="cwSend">Send</button>
    </div>
  </aside>

  <div class="cw-resizer" id="cwResizer" role="separator" aria-orientation="vertical" title="Drag to resize. Double-click to reset."></div>

  <div class="cowork-main">
    <div class="ahead">
      <p class="ey">Venture Numbers</p>
      <h1>Venture Numbers</h1>
      <p class="sub">The revenue model, lane by lane: scenarios, assumptions, and the gating facts that would firm them up. Ask Co-Intelligence here, or edit the cells directly. Every change is a revision.</p>
    </div>

    <div class="vn-banner">
      <b>Placeholder grade</b><br>
      Every figure on this page is a placeholder mirrored from
      {{ snapshot.model_version != '' ? snapshot.model_version : 'the modeling workbook' }}{{ snapshot.as_of != '' ? ', as of ' ~ snapshot.as_of : '' }}.
      {{ snapshot.note }} Confirmed gating facts are marked; everything else is unverified modeling. The workbook stays the modeling tool; this page is the status surface.
    </div>

    <div class="vn-roll">
      <h2>Roll-up across all lanes (CAD per year, placeholder grade)</h2>
      <table class="vt" id="vnRoll">
        <thead><tr><th>Scenario</th>{% for y in 1..years %}<th>Yr {{ y }}</th>{% endfor %}</tr></thead>
        <tbody>
          {% for s in scenarios %}
          <tr data-scenario="{{ s }}">
            <td>{{ s }}</td>
            {% for v in rollup[s] %}<td data-y="{{ loop.index }}">{{ v|number_format(0, '.', ',') }}</td>{% endfor %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
      <p class="vn-share">Technology carries <b id="vnShare">{{ tech_share }}%</b> of the likely Yr 5 roll-up.</p>
    </div>

    <div class="grid">
      {% for lane in lanes %}
      <div class="card" id="lane-{{ lane.key }}" data-key="{{ lane.key }}">
        <div class="card-top">
          <h4>{{ lane.title }}</h4>
          {% if can_edit %}<button type="button" class="vn-save" data-key="{{ lane.key }}" disabled>Save changes</button>{% endif %}
        </div>
        {% if lane.summary is not empty %}<p class="sum">{{ lane.summary }}</p>{% endif %}
        <table class="vt">
          <thead><tr><th>Scenario</th>{% for y in 1..years %}<th>Yr {{ y }}</th>{% endfor %}</tr></thead>
          <tbody>
            {% for s in scenarios %}
            <tr>
              <td>{{ s }}</td>
              {% for v in lane.grid[s] %}
              <td>
                {% if can_edit %}
                <input type="text" inputmode="numeric" value="{{ v }}" data-field="y{{ loop.index }}_{{ s }}" data-orig="{{ v }}" aria-label="{{ lane.title }} {{ s }} year {{ loop.index }}">
                {% else %}
                {{ v|number_format(0, '.', ',') }}
                {% endif %}
              </td>
              {% endfor %}
            </tr>
            {% endfor %}
          </tbody>
        </table>
        <div class="vn-ass" data-key="{{ lane.key }}">
          <h5>Assumptions {% if can_edit %}<button type="button" class="vn-edit" aria-expanded="false">Edit</button>{% endif %}</h5>
          <ul>
            {% for a in lane.assumptions %}<li>{{ a }}</li>{% endfor %}
          </ul>
          {% if can_edit %}
          <textarea rows="4" hidden aria-label="Assumptions for {{ lane.title }}, one per line">{{ lane.assumptions|join("\n") }}</textarea>
          {% endif %}
        </div>
        {% if lane.facts is not empty %}
        <div class="vn-facts">
          <h5>Gating facts</h5>
          {% for f in lane.facts %}
          <div class="fact" id="fact-{{ f.key }}" data-key="{{ f.key }}">
            <div class="fact-top">
              <span class="fstat f-{{ f.status }}">{{ f.status }}</span>
              <b>{{ f.label }}</b>
            </div>
            <div class="fd">{{ f.detail }}</div>
            <div class="fby">{%- if f.status == 'confirmed' and f.confirmed_by is not empty -%}Confirmed by {{ f.confirmed_by }} &middot; {{ f.confirmed_at }}{%- endif -%}</div>
            {% if can_confirm %}
            <div class="fact-act">
              <button type="button" class="fbtn" data-key="{{ f.key }}" data-next="{{ f.status == 'confirmed' ? 'placeholder' : 'confirmed' }}">{{ f.status == 'confirmed' ? 'Back to placeholder' : 'Confirm' }}</button>
              <button type="button" class="hbtn fhist" data-key="{{ f.key }}" aria-expanded="false">History</button>
            </div>
            <div class="hist fact-hist" data-key="{{ f.key }}" hidden></div>
            {% endif %}
          </div>
          {% endfor %}
        </div>
        {% endif %}
        <div class="cfoot">
          <div class="edited" data-key="{{ lane.key }}">
            {%- if lane.last_edited_by is not empty -%}Last edited by {{ lane.last_edited_by }} &middot; {{ lane.last_edited_at }}{%- endif -%}
          </div>
          <button type="button" class="hbtn lhist" data-key="{{ lane.key }}" aria-expanded="false">History</button>
        </div>
        <div class="hist lane-hist" data-key="{{ lane.key }}" hidden></div>
      </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
// Lane work surface: inline grid + assumption edits (saved as revisions),
// gating-fact confirmation flips, history panels.
(function(){
  function esc(s){ return String(s==null?'':s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
  function money(v){ var n=parseInt(v,10); return isNaN(n)?String(v):n.toLocaleString('en-CA'); }
  function stamp(key, by, at){
    var el=document.querySelector('.edited[data-key="'+key+'"]');
    if(el && by){ el.innerHTML='Last edited by '+esc(by)+' · '+esc(at); el.classList.add('saveflash'); setTimeout(function(){el.classList.remove('saveflash');},900); }
  }
  function applyRollup(rollup){
    if(!rollup) return;
    Object.keys(rollup).forEach(function(s){
      var row=document.querySelector('#vnRoll tr[data-scenario="'+s+'"]');
      if(!row) return;
      rollup[s].forEach(function(v,i){
        var cell=row.querySelector('td[data-y="'+(i+1)+'"]');
        if(cell) cell.textContent=money(v);
      });
    });
    var tech=document.getElementById('lane-technology');
    var share=document.getElementById('vnShare');
    if(tech && share && rollup.likely){
      var total=rollup.likely[rollup.likely.length-1]||0;
      var input=tech.querySelector('input[data-field="y5_likely"]');
      var v=input?parseInt(input.value,10):0;
      if(total>0 && !isNaN(v)){ share.textContent=Math.round(v/total*100)+'%'; }
    }
  }
  function post(url, body){
    return fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify(body)})
      .then(function(r){ return r.json().catch(function(){return {ok:false};}); });
  }

  // Grid + assumptions: dirty tracking per lane, one Save per card.
  document.querySelectorAll('.card[data-key]').forEach(function(card){
    var key=card.getAttribute('data-key');
    var saveBtn=card.querySelector('.vn-save');
    if(!saveBtn) return;
    var assBox=card.querySelector('.vn-ass');
    var assText=assBox?assBox.querySelector('textarea'):null;
    var assDirty=false;
    function refresh(){
      var dirty=assDirty;
      card.querySelectorAll('input[data-field]').forEach(function(inp){
        var d=inp.value.trim()!==inp.getAttribute('data-orig');
        inp.classList.toggle('dirty',d);
        if(d) dirty=true;
      });
      saveBtn.disabled=!dirty;
    }
    card.querySelectorAll('input[data-field]').forEach(function(inp){
      inp.addEventListener('input',refresh);
    });
    if(assBox){
      var editBtn=assBox.querySelector('.vn-edit');
      var list=assBox.querySelector('ul');
      if(editBtn && assText){
        editBtn.addEventListener('click',function(){
          var open=assText.hidden;
          assText.hidden=!open; list.hidden=open;
          editBtn.textContent=open?'Close':'Edit';
          editBtn.setAttribute('aria-expanded',open?'true':'false');
          if(open){ assText.focus(); }
        });
        assText.addEventListener('input',function(){ assDirty=true; refresh(); });
      }
    }
    saveBtn.addEventListener('click',function(){
      var changes={};
      var bad=false;
      card.querySelectorAll('input[data-field]').forEach(function(inp){
        if(inp.value.trim()===inp.getAttribute('data-orig')) return;
        var v=inp.value.trim().replace(/[, ]/g,'');
        if(!/^\d+$/.test(v)){ bad=true; inp.classList.add('dirty'); return; }
        changes[inp.getAttribute('data-field')]=parseInt(v,10);
      });
      if(bad){ alert('Scenario values must be whole non-negative numbers.'); return; }
      if(assDirty && assText){
        changes.assumptions=assText.value.split('\n').map(function(l){return l.trim();}).filter(function(l){return l!=='';});
      }
      if(Object.keys(changes).length===0) return;
      saveBtn.disabled=true;
      post('/anokii/ventures/lane/save',{key:key,changes:changes}).then(function(d){
        if(!d||!d.ok){ alert((d&&d.error)||'Could not save the lane.'); saveBtn.disabled=false; return; }
        card.querySelectorAll('input[data-field]').forEach(function(inp){
          var v=inp.value.trim().replace(/[, ]/g,'');
          if(/^\d+$/.test(v)){ inp.value=v; inp.setAttribute('data-orig',v); }
          inp.classList.remove('dirty');
        });
        if(assDirty && assText){
          var list=assBox.querySelector('ul');
          list.innerHTML=assText.value.split('\n').map(function(l){return l.trim();}).filter(function(l){return l!=='';}).map(function(l){return '<li>'+esc(l)+'</li>';}).join('');
          assDirty=false;
        }
        stamp(key, d.last_edited_by, d.last_edited_at);
        applyRollup(d.rollup);
        refreshHistIfOpen('.lane-hist', key, loadLaneHistory);
      });
    });
  });

  // Gating facts: confirm / back-to-placeholder flips.
  document.querySelectorAll('.fbtn').forEach(function(btn){
    btn.addEventListener('click',function(){
      var key=btn.getAttribute('data-key');
      var next=btn.getAttribute('data-next');
      btn.disabled=true;
      post('/anokii/ventures/fact/save',{key:key,status:next}).then(function(d){
        btn.disabled=false;
        if(!d||!d.ok){ alert((d&&d.error)||'Could not update the gating fact.'); return; }
        var fact=document.getElementById('fact-'+key);
        if(!fact) return;
        var pill=fact.querySelector('.fstat');
        pill.textContent=d.status;
        pill.className='fstat f-'+d.status;
        var by=fact.querySelector('.fby');
        by.innerHTML=d.status==='confirmed'&&d.confirmed_by?('Confirmed by '+esc(d.confirmed_by)+' · '+esc(d.confirmed_at)):'';
        btn.setAttribute('data-next', d.status==='confirmed'?'placeholder':'confirmed');
        btn.textContent=d.status==='confirmed'?'Back to placeholder':'Confirm';
        refreshHistIfOpen('.fact-hist', key, loadFactHistory);
      });
    });
  });

  // History panels (lanes + facts).
  function renderHistory(panel, revisions){
    if(!revisions || !revisions.length){ panel.innerHTML='<p class="empty">No history yet.</p>'; return; }
    var html='<ol>';
    revisions.forEach(function(r){
      html+='<li><span class="stat"></span><div>'
        +'<div class="sum">'+esc(r.summary||'Edit')+(r.is_current?' <span class="cur">(current)</span>':'')+'</div>'
        +'<div class="meta">'+esc(r.editor)+' · '+esc(r.when)+'</div>'
        +'</div></li>';
    });
    html+='</ol>';
    panel.innerHTML=html;
  }
  function loadLaneHistory(key){
    var panel=document.querySelector('.lane-hist[data-key="'+key+'"]');
    if(!panel) return Promise.resolve();
    panel.innerHTML='<p class="empty">Loading...</p>';
    return fetch('/anokii/ventures/lane/'+encodeURIComponent(key)+'/history',{credentials:'same-origin'})
      .then(function(r){ return r.json().catch(function(){return {ok:false};}); })
      .then(function(d){ renderHistory(panel, d&&d.ok?d.revisions:[]); });
  }
  function loadFactHistory(key){
    var panel=document.querySelector('.fact-hist[data-key="'+key+'"]');
    if(!panel) return Promise.resolve();
    panel.innerHTML='<p class="empty">Loading...</p>';
    return fetch('/anokii/ventures/fact/'+encodeURIComponent(key)+'/history',{credentials:'same-origin'})
      .then(function(r){ return r.json().catch(function(){return {ok:false};}); })
      .then(function(d){ renderHistory(panel, d&&d.ok?d.revisions:[]); });
  }
  function refreshHistIfOpen(sel, key, loader){
    var panel=document.querySelector(sel+'[data-key="'+key+'"]');
    if(panel && panel.classList.contains('open')){ loader(key); }
  }
  function wireHist(btnSel, panelSel, loader){
    document.querySelectorAll(btnSel).forEach(function(btn){
      btn.addEventListener('click',function(){
        var key=btn.getAttribute('data-key');
        var panel=document.querySelector(panelSel+'[data-key="'+key+'"]');
        if(!panel) return;
        var open=panel.classList.toggle('open');
        panel.hidden=!open;
        btn.setAttribute('aria-expanded',open?'true':'false');
        btn.textContent=open?'Hide history':'History';
        if(open){ loader(key); }
      });
    });
  }
  wireHist('.hbtn.lhist','.lane-hist',loadLaneHistory);
  wireHist('.hbtn.fhist','.fact-hist',loadFactHistory);
})();

// Co-Intelligence companion: the live agent endpoints with confirm-before-apply.
// A proposal targeting a lane or gating fact visible on the page previews as a
// draft on that card; on an applied change the page refreshes.
(function(){
  var stream=document.getElementById('cwStream');
  var input=document.getElementById('cwInput');
  var sendBtn=document.getElementById('cwSend');
  var chips=document.getElementById('cwChips');
  var newBtn=document.getElementById('cwNew');
  if(!stream||!input||!sendBtn) return;
  var cid=0, busy=false, didApply=false;
  var CIDKEY='anokiiVenturesCid';
  function rememberCid(id){ cid=id; try{ localStorage.setItem(CIDKEY,String(id)); }catch(e){} }
  function forgetCid(){ cid=0; try{ localStorage.removeItem(CIDKEY); }catch(e){} }

  function esc(s){ return String(s==null?'':s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
  function fmt(t){ if(window.AnokiiMd && window.AnokiiMd.render){ return window.AnokiiMd.render(t); } return '<p>'+esc(t).replace(/\n/g,'<br>')+'</p>'; }
  var CELL=/^y([1-5])_(worst|likely|best)$/;
  function fmtVal(v){
    if(v===null||v===undefined||v==='') return '(none)';
    if(typeof v==='object') return JSON.stringify(v);
    if(typeof v==='number'||/^\d+$/.test(String(v))) return parseInt(v,10).toLocaleString('en-CA');
    var s=String(v); return s.length>140?s.slice(0,137)+'...':s;
  }
  function fieldLabel(f){
    var m=CELL.exec(f);
    return m?('Yr '+m[1]+' '+m[2]):f;
  }
  function addMsg(role){ var m=document.createElement('div'); m.className='imsg '+(role==='user'?'user':'ai'); var a=document.createElement('div'); a.className='av'; a.textContent=role==='user'?'YOU':'CI'; var b=document.createElement('div'); b.className='ibub'; m.appendChild(a); m.appendChild(b); stream.appendChild(m); stream.scrollTop=stream.scrollHeight; return b; }
  function frames(buf,on){ var parts=buf.split('\n\n'); var rest=parts.pop(); parts.forEach(function(bl){ var ev='message',data=''; bl.split('\n').forEach(function(l){ if(l.indexOf('event:')===0)ev=l.slice(6).trim(); else if(l.indexOf('data:')===0)data+=l.slice(5).trim(); }); if(data){ try{ on(ev,JSON.parse(data)); }catch(e){} } }); return rest; }

  function send(q){ q=(q||input.value||'').trim(); if(!q||busy) return; if(chips){ chips.remove(); chips=null; } input.value=''; input.style.height='42px'; addMsg('user').textContent=q; var bub=addMsg('ai'); bub.innerHTML='<span class="iwork"><span class="d"></span>Thinking...</span>'; consume('/anokii/cointelligence/send',{question:q,conversation_id:cid},bub); }

  function consume(url,body,bub){
    busy=true; sendBtn.disabled=true; var raw='',proposed=false,started=false;
    fetch(url,{method:'POST',headers:{'Content-Type':'application/json','Accept':'text/event-stream'},credentials:'same-origin',body:JSON.stringify(body)})
    .then(function(r){ if(!r.ok||!r.body) throw new Error('bad'); var rd=r.body.getReader(),dec=new TextDecoder(),buf='';
      function pump(){ return rd.read().then(function(res){ if(res.done){ fin(); return; } buf+=dec.decode(res.value,{stream:true}); buf=frames(buf,function(ev,d){
        if(ev==='meta'){ if(d.conversation_id) rememberCid(d.conversation_id); }
        else if(ev==='delta'){ if(!started){ bub.textContent=''; started=true; } raw+=d.text||''; bub.textContent=raw; stream.scrollTop=stream.scrollHeight; }
        else if(ev==='proposal'){ proposed=true; routeProposal(bub,raw,d); }
        else if(ev==='applied'){ if(d.ok) didApply=true; }
      }); return pump(); }); }
      function fin(){ if(!proposed){ bub.innerHTML=fmt(raw)||'<p>Done.</p>'; } busy=false; sendBtn.disabled=false; stream.scrollTop=stream.scrollHeight; if(didApply){ var n=addMsg('ai'); n.innerHTML='<span class="iwork"><span class="d"></span>Change applied. Refreshing the lanes...</span>'; setTimeout(function(){ location.reload(); },1400); } }
      return pump();
    }).catch(function(){ if(!proposed) bub.innerHTML='<p>Sorry, something went wrong. Please try again.</p>'; busy=false; sendBtn.disabled=false; });
  }

  function card(bub,lead,d){
    var h=lead?fmt(lead):''; h+='<div class="iprop'+(d.destructive?' danger':'')+'"><div class="ph">Proposed change'+(d.destructive?' (delete)':'')+'</div><div class="ps">'+esc(d.summary||'')+'</div>';
    if(d.diff&&d.diff.length){ h+='<ul class="pd">'; d.diff.forEach(function(x){ h+='<li><span class="f">'+esc(fieldLabel(x.field))+'</span><span class="b">'+esc(fmtVal(x.before))+'</span><span>&rarr;</span><span class="a">'+esc(fmtVal(x.after))+'</span></li>'; }); h+='</ul>'; }
    h+='<div class="pact"><button class="ipb ok">Approve</button><button class="ipb no">Reject</button></div></div>';
    bub.innerHTML=h; busy=false; sendBtn.disabled=false;
    var c=bub.querySelector('.iprop');
    c.querySelector('.ok').addEventListener('click',function(){ decide(c,d.token,'approve'); });
    c.querySelector('.no').addEventListener('click',function(){ decide(c,d.token,'reject'); });
    stream.scrollTop=stream.scrollHeight;
  }
  function decide(c,token,decision){ if(busy) return; [].slice.call(c.querySelectorAll('.ipb')).forEach(function(b){ b.disabled=true; }); var bub=addMsg('ai'); bub.innerHTML='<span class="iwork"><span class="d"></span>'+(decision==='approve'?'Applying...':'Cancelling...')+'</span>'; consume('/anokii/cointelligence/apply',{token:token,decision:decision},bub); }

  // A proposal that targets a lane (or a gating fact whose lane card is on the
  // page) is previewed as a draft on that card. Anything else falls back to a
  // card inside the conversation.
  function targetCard(d){
    if(!d.target||!d.target.pid) return null;
    if(d.target.entity_type==='venture_lane'){ return document.getElementById('lane-'+d.target.pid); }
    if(d.target.entity_type==='gating_fact'){
      var fact=document.getElementById('fact-'+d.target.pid);
      return fact?fact.closest('.card'):null;
    }
    return null;
  }
  function routeProposal(bub,lead,d){
    var pcard=targetCard(d);
    if(pcard){ previewOnLane(pcard,d); pointer(bub,lead,pcard); busy=false; sendBtn.disabled=false; stream.scrollTop=stream.scrollHeight; }
    else { card(bub,lead,d); }
  }
  function pointer(bub,lead,pcard){
    var t=pcard.querySelector('h4'); var title=t?t.textContent:'the lane';
    var h=lead?fmt(lead):'';
    h+='<p class="cw-point">I drafted this on the <strong>'+esc(title)+'</strong> card. Review and approve it there.</p>';
    bub.innerHTML=h;
  }
  function draftBody(d){
    var diff=d.diff||[];
    if(!diff.length) return '<div class="pd-row">'+esc(d.summary||'Proposed change')+'</div>';
    var out='';
    diff.forEach(function(x){
      var f=x.field;
      if(f==='(delete)'){ out+='<div class="pd-row">This item will be deleted.</div>'; return; }
      out+='<div class="pd-row"><span class="f">'+esc(fieldLabel(f))+'</span><span class="pd-was">'+esc(fmtVal(x.before))+'</span> &rarr; <span class="pd-new">'+esc(fmtVal(x.after))+'</span></div>';
    });
    return out;
  }
  function previewOnLane(pcard,d){
    var old=pcard.querySelector('.lane-draft'); if(old) old.remove();
    var panel=document.createElement('div');
    panel.className='lane-draft'+(d.destructive?' danger':'');
    panel.innerHTML='<div class="pd-h">&#9998; Draft from Co-Intelligence</div><div class="pd-body">'+draftBody(d)+'</div><div class="pd-act"><button class="ipb ok">Approve</button><button class="ipb no">Reject</button></div>';
    var top=pcard.querySelector('.card-top');
    if(top&&top.nextSibling) pcard.insertBefore(panel,top.nextSibling); else pcard.appendChild(panel);
    pcard.classList.add('previewing');
    panel.querySelector('.ok').addEventListener('click',function(){ decideLane(d,'approve',pcard); });
    panel.querySelector('.no').addEventListener('click',function(){ decideLane(d,'reject',pcard); });
    try{ pcard.scrollIntoView({behavior:'smooth',block:'center'}); }catch(e){}
  }
  function clearLanePreview(pcard){ var p=pcard.querySelector('.lane-draft'); if(p) p.remove(); pcard.classList.remove('previewing'); }
  function decideLane(d,decision,pcard){
    if(busy) return;
    var panel=pcard.querySelector('.lane-draft');
    if(panel){ [].slice.call(panel.querySelectorAll('.ipb')).forEach(function(b){ b.disabled=true; }); }
    if(decision==='reject'){ clearLanePreview(pcard); }
    var bub=addMsg('ai'); bub.innerHTML='<span class="iwork"><span class="d"></span>'+(decision==='approve'?'Applying...':'Cancelling...')+'</span>';
    consume('/anokii/cointelligence/apply',{token:d.token,decision:decision},bub);
  }

  sendBtn.addEventListener('click', function(){ send(); });
  input.addEventListener('keydown', function(e){ if(e.key==='Enter'&&!e.shiftKey){ e.preventDefault(); send(); } });
  input.addEventListener('input', function(){ input.style.height='42px'; input.style.height=Math.min(input.scrollHeight,140)+'px'; });
  if(chips){ chips.querySelectorAll('.cw-chip').forEach(function(b){ b.addEventListener('click', function(){ send(b.textContent); }); }); }

  // Thread persistence: the Ventures thread id survives the reload that
  // follows applying a change. On load, rehydrate prior turns.
  function renderTurn(m){ var bub=addMsg(m.role==='user'?'user':'ai'); if(m.role==='user'){ bub.textContent=m.content; } else { bub.innerHTML=fmt(m.content)||'<p>...</p>'; } return bub; }
  function loadThread(id){
    fetch('/anokii/cointelligence/'+encodeURIComponent(id)+'/messages',{credentials:'same-origin'})
      .then(function(r){ return r.ok?r.json():null; })
      .then(function(d){
        if(!d||!d.ok){ forgetCid(); return; }
        cid=id;
        if(!d.messages||!d.messages.length) return;
        var intro=document.getElementById('cwIntro'); if(intro) intro.remove();
        if(chips){ chips.remove(); chips=null; }
        d.messages.forEach(renderTurn);
        stream.scrollTop=stream.scrollHeight;
      }).catch(function(){});
  }
  function newChat(){
    if(busy) return;
    forgetCid(); didApply=false;
    stream.innerHTML='';
    var bub=addMsg('ai'); var wrap=bub.closest('.imsg'); if(wrap) wrap.id='cwIntro';
    bub.innerHTML='Aanii. Fresh thread. Ask me about the venture lanes, or tell me what to change. When I draft an edit, it appears on the lane card for you to approve.';
    input.focus();
  }
  if(newBtn){ newBtn.addEventListener('click', newChat); }
  var startId=0; try{ startId=parseInt(localStorage.getItem(CIDKEY)||'0',10)||0; }catch(e){}
  if(startId>0){ loadThread(startId); }
})();

// Resizable gutter between the chat and the lane rail; width persists.
(function(){
  var cowork=document.querySelector('.cowork');
  var rail=document.querySelector('.cowork-main');
  var rez=document.getElementById('cwResizer');
  if(!cowork||!rail||!rez) return;
  var KEY='anokiiVenturesRailW', MIN=380, MAXHARD=860, cur=520;
  function maxW(){ return Math.min(MAXHARD, Math.round(cowork.getBoundingClientRect().width*0.66)); }
  function setW(w){ w=Math.round(Math.max(MIN, Math.min(maxW(), w))); cur=w; rail.style.setProperty('--rail-w', w+'px'); }
  var stored=0; try{ stored=parseInt(localStorage.getItem(KEY)||'0',10)||0; }catch(e){}
  if(stored>0) setW(stored);
  var dragging=false;
  function pt(e){ return (e.touches&&e.touches[0])?e.touches[0].clientX:e.clientX; }
  function onDown(e){ dragging=true; rez.classList.add('drag'); document.body.style.userSelect='none'; document.body.style.cursor='col-resize'; e.preventDefault(); }
  function onMove(e){ if(!dragging) return; setW(cowork.getBoundingClientRect().right - pt(e)); e.preventDefault(); }
  function onUp(){ if(!dragging) return; dragging=false; rez.classList.remove('drag'); document.body.style.userSelect=''; document.body.style.cursor=''; try{ localStorage.setItem(KEY,String(cur)); }catch(e){} }
  rez.addEventListener('mousedown',onDown);
  window.addEventListener('mousemove',onMove);
  window.addEventListener('mouseup',onUp);
  rez.addEventListener('touchstart',onDown,{passive:false});
  window.addEventListener('touchmove',onMove,{passive:false});
  window.addEventListener('touchend',onUp);
  rez.addEventListener('dblclick',function(){ rail.style.removeProperty('--rail-w'); cur=520; try{ localStorage.removeItem(KEY); }catch(e){} });
})();
</script>
{% endblock %}
