{% extends "anokii/_shell.html.twig" %}

{% block anokii_styles %}
  .panel{background:#fff;border:1px solid var(--line);border-radius:8px;padding:24px 24px;max-width:560px;margin-bottom:18px}
  .panel h2{font-family:"Oswald",sans-serif;font-size:13px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--cyan2);margin:0 0 16px}
  .fld{margin-bottom:13px}
  .fld label{display:block;font-family:"Oswald",sans-serif;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:5px}
  .fld input{width:100%;border:1px solid var(--line);border-radius:5px;padding:10px 12px;font:inherit;font-size:14px;background:#fcfcfa}
  .fld input:focus{outline:2px solid #e3f4f8;border-color:var(--cyan)}
  .abtn{background:var(--cyan2);color:#fff;border:none;border-radius:5px;padding:10px 18px;font-family:"Oswald",sans-serif;font-weight:600;letter-spacing:.08em;text-transform:uppercase;font-size:12.5px;cursor:pointer}
  .abtn:hover{background:#0f7488}
  .msg{font-size:13px;margin-top:10px;min-height:18px}
  .msg.ok{color:#0f6b3f} .msg.bad{color:#a4291c}
  .stub{color:var(--muted);font-size:13.5px}
{% endblock %}

{% block anokii_content %}
<div class="ahead">
  <p class="ey">Account</p>
  <h1>Settings</h1>
  <p class="sub">Your profile and password. Workspace-level settings are coming soon.</p>
</div>

<div class="panel">
  <h2>Profile</h2>
  <form id="profileForm">
    <div class="fld"><label for="name">Name</label><input type="text" id="name" value="{{ profile_name }}"></div>
    <div class="fld"><label for="email">Email</label><input type="email" id="email" value="{{ profile_email }}"></div>
    <button class="abtn" type="submit">Save profile</button>
    <div class="msg" id="profileMsg"></div>
  </form>
</div>

<div class="panel">
  <h2>Change password</h2>
  <form id="pwForm">
    <div class="fld"><label for="current">Current password</label><input type="password" id="current" autocomplete="current-password"></div>
    <div class="fld"><label for="newpw">New password</label><input type="password" id="newpw" autocomplete="new-password" minlength="10"></div>
    <button class="abtn" type="submit">Change password</button>
    <div class="msg" id="pwMsg"></div>
  </form>
</div>

<div class="panel">
  <h2>Workspace</h2>
  <p class="stub">Workspace-level settings (members, branding, exports) will live here in a later pass.</p>
</div>

<script>
(function(){
  function post(body){
    return fetch('/admin/anokii/settings', {method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify(body)})
      .then(function(r){ return r.json().catch(function(){return {ok:false,error:'Something went wrong.'};}); });
  }
  function show(el, ok, text){ el.className = 'msg ' + (ok?'ok':'bad'); el.textContent = text; }

  document.getElementById('profileForm').addEventListener('submit', function(e){
    e.preventDefault();
    var m=document.getElementById('profileMsg');
    post({name:document.getElementById('name').value, email:document.getElementById('email').value})
      .then(function(d){ show(m, !!(d&&d.ok), (d&&d.ok)?'Profile saved.':((d&&d.error)||'Could not save.')); });
  });
  document.getElementById('pwForm').addEventListener('submit', function(e){
    e.preventDefault();
    var m=document.getElementById('pwMsg');
    var np=document.getElementById('newpw').value;
    if(np.length<10){ show(m,false,'New password must be at least 10 characters.'); return; }
    post({current_password:document.getElementById('current').value, new_password:np})
      .then(function(d){ if(d&&d.ok){ show(m,true,'Password changed.'); document.getElementById('pwForm').reset(); } else { show(m,false,(d&&d.error)||'Could not change password.'); } });
  });
})();
</script>
{% endblock %}
