{% extends "anokii/_shell.html.twig" %}

{% block anokii_styles %}
  .ahero{border-radius:16px;margin-bottom:22px}
  .ahero .inner{position:relative;padding:30px 32px}
  .ahero h1{font-family:"Anton",sans-serif;text-transform:uppercase;letter-spacing:.01em;color:#fff;font-size:34px;margin:0 0 4px;max-width:none}
  .ahero .mean{position:relative;color:#7fd6e8;font-size:13px;font-style:italic;margin:0 0 10px;font-family:"Oswald",sans-serif}
  .ahero p{margin:0;color:#c4ccd0;max-width:640px;position:relative;font-size:15.5px;line-height:1.6}
  .ahero .chips{display:flex;gap:8px;margin-top:16px;flex-wrap:wrap;position:relative}
  .ahero .chips span{background:rgba(31,182,214,.14);border:1px solid rgba(31,182,214,.3);border-radius:20px;padding:5px 12px;font-size:12px;color:#bfe9f2;font-family:"Oswald",sans-serif;letter-spacing:.02em}
  .tiles{display:grid;grid-template-columns:repeat(auto-fill,minmax(234px,1fr));gap:16px}
  .tile{background:#fff;border:1px solid var(--line);border-radius:12px;padding:18px;display:flex;flex-direction:column;gap:9px;text-decoration:none;color:inherit;transition:transform .12s,box-shadow .12s,border-color .12s}
  .tile:hover{transform:translateY(-3px);box-shadow:0 14px 34px rgba(10,14,18,.10);border-color:var(--cyan)}
  .tile .tic{width:42px;height:42px;border-radius:11px;display:flex;align-items:center;justify-content:center;color:#fff}
  .tile .tic svg{width:22px;height:22px}
  .tile .tic.live{background:var(--cyan2)} .tile .tic.soon{background:#2b3a40}
  .tile h3{margin:3px 0 0;font-family:"Anton",sans-serif;text-transform:uppercase;letter-spacing:.01em;font-size:19px;color:var(--ink)}
  .tile p{margin:0;font-size:14px;line-height:1.5;color:var(--muted);flex:1}
  .tmeta{font-family:"Oswald",sans-serif;font-size:11.5px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;width:fit-content}
  .tmeta.live{color:var(--cyan2)}
  .tmeta.soon{color:#7a4e1d;background:#f3e9da;border-radius:3px;padding:2px 8px}
  .tile.is-soon{opacity:.85}
{% endblock %}

{% block anokii_content %}
<section class="hero ahero"><div class="grid-bg"></div><div class="glow"></div>
  <div class="inner">
    <h1>Aanii, {{ user_label }}</h1>
    <div class="mean">Anokii · Anishinaabemowin for "she/he works"</div>
    <p>Welcome to FNPI's own Anokii workspace, running on the Waaseyaa platform. Tools live here, and the data stays on FNPI's own infrastructure. This is the platform proving itself on FNPI first.</p>
    <div class="chips">
      <span>Identity Workspace live</span>
      <span>Sovereign at rest</span>
      <span>Hosted in Canada</span>
      <span>More tools coming</span>
    </div>
  </div>
</section>

<div class="tiles">
  {% for m in modules %}
    {% if m.tile %}
      <a class="tile{{ m.live ? '' : ' is-soon' }}" href="{{ m.href }}">
        <span class="tic {{ m.live ? 'live' : 'soon' }}"><svg viewBox="0 0 24 24">{{ m.icon|raw }}</svg></span>
        <h3>{{ m.label }}</h3>
        <p>{{ m.desc }}</p>
        {% if m.live %}<span class="tmeta live">Open &rarr;</span>{% else %}<span class="tmeta soon">Coming soon</span>{% endif %}
      </a>
    {% endif %}
  {% endfor %}
</div>
{% endblock %}
