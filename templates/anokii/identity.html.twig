{% extends "anokii/_shell.html.twig" %}

{% block anokii_styles %}
  :root{
    --green:#138a55; --green-soft:#e4f7ee;
    --amber:#a96a00; --amber-soft:#fff3df;
    --orange:#c4631f; --orange-soft:#fbe9da;
    --grey:#5b6172; --grey-soft:#eef0f4;
    --cyan-soft:#e3f4f8;
    --card-shadow:0 1px 3px rgba(10,14,18,.05),0 8px 24px rgba(10,14,18,.06);
  }
  /* maturity card */
  .maturity{background:#fff;border:1px solid var(--line);border-radius:14px;padding:20px 22px;margin-bottom:28px;box-shadow:var(--card-shadow)}
  .maturity h2{font-size:11.5px;text-transform:uppercase;letter-spacing:.14em;color:var(--muted);margin:0 0 13px;font-weight:600;font-family:"Oswald",sans-serif}
  .bar{display:flex;height:14px;border-radius:8px;overflow:hidden;border:1px solid var(--line);background:var(--bg)}
  .bar span{display:block;height:100%;transition:width .3s}
  .legend{display:flex;flex-wrap:wrap;gap:18px;margin-top:13px;font-size:13px;color:var(--muted);font-family:"Oswald",sans-serif}
  .legend b{color:var(--ink);font-weight:700}
  .dot{display:inline-block;width:10px;height:10px;border-radius:3px;margin-right:6px;vertical-align:middle}
  .d-defined{background:var(--green)} .d-draft{background:var(--amber)} .d-work{background:var(--orange)} .d-gap{background:var(--grey)}
  /* sections */
  section.sec{margin:30px 0}
  .sec-h{display:flex;align-items:baseline;gap:11px;margin:0 0 5px}
  .sec-h .n{font-family:"Oswald",sans-serif;font-size:14px;font-weight:700;color:var(--cyan2);letter-spacing:.04em}
  .sec-h h3{font-family:"Anton",sans-serif;text-transform:uppercase;letter-spacing:.01em;font-size:23px;margin:0;color:var(--ink)}
  .sec-sub{color:var(--muted);margin:0 0 16px;font-size:14.5px;line-height:1.55;max-width:80ch}
  .grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start}
  @media(max-width:760px){.grid{grid-template-columns:1fr}}
  /* card (Anokii style) */
  .card{background:#fff;border:1px solid var(--line);border-radius:14px;padding:18px;display:flex;flex-direction:column;gap:12px;box-shadow:var(--card-shadow)}
  .card.full{grid-column:1 / -1}
  .card-top{display:flex;justify-content:space-between;align-items:center;gap:10px}
  .card h4{margin:0;font-family:"Oswald",sans-serif;font-weight:600;font-size:16.5px;color:var(--ink);letter-spacing:.01em}
  /* status pill (working selector) */
  .status{font-size:11.5px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;border:1px solid transparent;border-radius:20px;padding:5px 12px;cursor:pointer;appearance:none;font-family:"Oswald",sans-serif;flex:0 0 auto}
  .status:focus{outline:none;box-shadow:0 0 0 3px rgba(31,182,214,.16)}
  .s-defined{background:var(--green-soft);color:var(--green)}
  .s-draft{background:var(--amber-soft);color:var(--amber)}
  .s-work{background:var(--orange-soft);color:var(--orange)}
  .s-gap{background:var(--grey-soft);color:var(--grey)}
  /* now content + quiet quotes */
  .now{font-size:15px;color:var(--ink);line-height:1.6}
  .now .lbl{display:block;font-size:11.5px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-bottom:4px;font-weight:600;font-family:"Oswald",sans-serif}
  .now blockquote{margin:4px 0 0;padding:1px 0 1px 13px;border-left:2px solid #cfe7ee;color:#3a4147;font-style:italic;font-size:15px}
  /* refined Decide callout */
  .decide{background:#f2f8fa;border-left:3px solid var(--cyan2);border-radius:0 8px 8px 0;padding:10px 13px;font-size:14px;color:#3a4147;line-height:1.55}
  .decide .dl{display:block;font-family:"Oswald",sans-serif;font-size:11.5px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cyan2);margin-bottom:3px}
  /* notes (Anokii input) — long content stays in a scroll well, never runs away */
  .notes label{display:block;font-size:11.5px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin:2px 0 5px;font-weight:600;font-family:"Oswald",sans-serif}
  .notes textarea{width:100%;border:1px solid var(--line);border-radius:9px;padding:10px 12px;font:inherit;font-size:14.5px;line-height:1.55;background:#fff;resize:vertical;min-height:46px;max-height:340px;overflow-y:auto;color:var(--ink);box-sizing:border-box}
  .notes textarea:focus{outline:none;border-color:var(--cyan);box-shadow:0 0 0 3px rgba(31,182,214,.14)}
  /* tag chips */
  .pills{display:flex;flex-wrap:wrap;gap:6px}
  .pill{font-size:12px;background:#eef1f3;border:1px solid var(--line);border-radius:20px;padding:3px 11px;color:#3a4147}
  .pill.cyan{background:var(--cyan-soft);border-color:#cdeaf1;color:var(--cyan2)}
  /* card footer: stamp + history toggle */
  .cfoot{display:flex;justify-content:space-between;align-items:center;gap:10px;border-top:1px solid var(--line);padding-top:10px;margin-top:1px}
  .edited{font-size:12px;color:var(--muted);font-family:"Oswald",sans-serif;letter-spacing:.02em;min-height:15px}
  .saveflash{color:var(--cyan2)}
  .hbtn{font-family:"Oswald",sans-serif;font-size:12px;font-weight:600;letter-spacing:.04em;color:var(--cyan2);background:none;border:none;cursor:pointer;padding:2px 4px;flex:0 0 auto}
  .hbtn:hover{text-decoration:underline}
  .hbtn:focus{outline:none;box-shadow:0 0 0 3px rgba(31,182,214,.16);border-radius:4px}
  /* history panel */
  .hist{display:none;border-top:1px dashed var(--line);padding-top:10px;margin-top:2px}
  .hist.open{display:block}
  .hist ol{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:9px}
  .hist li{display:flex;gap:10px;font-size:13px;line-height:1.45}
  .hist .stat{flex:0 0 auto;width:8px;height:8px;border-radius:2px;margin-top:5px}
  .hist .meta{color:var(--muted);font-family:"Oswald",sans-serif;font-size:11.5px;letter-spacing:.02em}
  .hist .sum{color:var(--ink)}
  .hist .cur{color:var(--cyan2);font-weight:700}
  .hist .empty{color:var(--muted);font-size:13px}
  /* identity assistant chat dock */
  .idock-toggle{position:fixed;right:22px;bottom:22px;z-index:40;display:inline-flex;align-items:center;gap:8px;background:var(--cyan2);color:#fff;border:none;border-radius:24px;padding:11px 18px;font-family:"Oswald",sans-serif;font-weight:600;font-size:14px;letter-spacing:.02em;cursor:pointer;box-shadow:0 6px 20px rgba(19,134,159,.35)}
  .idock-toggle:hover{background:#0f6f85}
  .idock{position:fixed;right:22px;bottom:22px;z-index:41;width:380px;max-width:calc(100vw - 32px);height:520px;max-height:calc(100vh - 90px);display:none;flex-direction:column;background:#fff;border:1px solid var(--line);border-radius:16px;box-shadow:0 18px 50px rgba(10,14,18,.22);overflow:hidden}
  .idock.open{display:flex}
  .idock-head{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;border-bottom:1px solid var(--line);background:#f7fbfc}
  .idock-head b{font-family:"Oswald",sans-serif;font-size:14px;color:var(--ink)}
  .idock-head small{display:block;font-size:11.5px;color:var(--muted)}
  .idock-x{background:none;border:none;font-size:21px;line-height:1;color:var(--muted);cursor:pointer;padding:0 6px}
  .idock-stream{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:12px;background:var(--bg)}
  .imsg{display:flex;gap:9px;align-items:flex-start}
  .imsg .av{flex:0 0 auto;width:26px;height:26px;border-radius:7px;font-family:"Oswald",sans-serif;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;color:#fff}
  .imsg.user .av{background:var(--ink)} .imsg.ai .av{background:var(--cyan2)}
  .ibub{background:#fff;border:1px solid var(--line);border-radius:11px;padding:9px 11px;font-size:14px;line-height:1.55;color:var(--ink);max-width:84%;overflow-wrap:anywhere}
  .imsg.user .ibub{background:#eef6f9;border-color:#d3e9f0}
  .ibub p{margin:0 0 7px} .ibub p:last-child{margin:0} .ibub strong{font-weight:700}
  .idock-foot{border-top:1px solid var(--line);padding:10px;display:flex;gap:8px}
  .idock-foot textarea{flex:1;border:1px solid var(--line);border-radius:9px;padding:9px 11px;font:inherit;font-size:14px;resize:none;height:40px;max-height:120px;color:var(--ink)}
  .idock-foot textarea:focus{outline:none;border-color:var(--cyan);box-shadow:0 0 0 3px rgba(31,182,214,.14)}
  .idock-send{background:var(--cyan2);color:#fff;border:none;border-radius:9px;padding:0 16px;font-family:"Oswald",sans-serif;font-weight:600;cursor:pointer}
  .idock-send:disabled{opacity:.5;cursor:default}
  .iwork{display:inline-flex;align-items:center;gap:7px;color:var(--muted);font-size:13px}
  .iwork .d{width:6px;height:6px;border-radius:50%;background:var(--cyan2);animation:ipulse 1s infinite}
  @keyframes ipulse{0%,100%{opacity:.3}50%{opacity:1}}
  .iprop{margin-top:8px;border:1px solid var(--cyan);border-radius:10px;background:#f2fafd;overflow:hidden}
  .iprop.danger{border-color:#d98b5f;background:#fdf3ec}
  .iprop .ph{font-family:"Oswald",sans-serif;font-size:11px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--cyan2);padding:7px 11px;border-bottom:1px solid #d7ecf3}
  .iprop.danger .ph{color:#c4631f}
  .iprop .ps{padding:8px 11px 3px;font-weight:600;font-size:13.5px;color:var(--ink)}
  .iprop ul.pd{list-style:none;margin:0;padding:3px 11px 7px;display:flex;flex-direction:column;gap:4px}
  .iprop ul.pd li{font-size:12.5px;line-height:1.4;display:flex;flex-wrap:wrap;gap:5px;align-items:baseline}
  .iprop .f{font-family:"Oswald",sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--muted);min-width:70px}
  .iprop .b{color:#9a4242;text-decoration:line-through;opacity:.85;overflow-wrap:anywhere} .iprop .a{color:#138a55;font-weight:600;overflow-wrap:anywhere}
  .iprop .pact{display:flex;gap:7px;padding:7px 11px 10px}
  .ipb{font-family:"Oswald",sans-serif;font-size:12.5px;font-weight:600;border-radius:7px;padding:5px 14px;cursor:pointer;border:1px solid transparent}
  .ipb.ok{background:var(--cyan);color:#06303a} .ipb.no{background:#fff;color:#5b6172;border-color:var(--line)} .ipb:disabled{opacity:.5;cursor:default}
{% endblock %}

{% block anokii_content %}
<div class="ahead">
  <p class="ey">Identity Workspace</p>
  <h1>Identity Workspace</h1>
  <p class="sub">A living canvas for defining who FNPI is, before more content gets built on top of it. Foundation first, expression last. Set each pillar's status, capture decisions in the notes, and evolve it together. Every edit is saved as a revision, so the full history of each pillar is kept and shared between accounts.</p>
</div>

{% set order = ['defined','draft','work','gap'] %}
{% set colorvar = {'defined':'var(--green)','draft':'var(--amber)','work':'var(--orange)','gap':'var(--grey)'} %}
<div class="maturity">
  <h2>Identity maturity</h2>
  <div class="bar" id="bar">
    {% for k in order %}
      <span data-k="{{ k }}" style="width: {{ counts.total ? (counts[k] / counts.total * 100)|round(2) : 0 }}%; background: {{ colorvar[k] }}"></span>
    {% endfor %}
  </div>
  <div class="legend">
    <span><span class="dot d-defined"></span><b id="c-defined">{{ counts.defined }}</b> Defined</span>
    <span><span class="dot d-draft"></span><b id="c-draft">{{ counts.draft }}</b> Draft / legacy</span>
    <span><span class="dot d-work"></span><b id="c-work">{{ counts.work }}</b> Needs work</span>
    <span><span class="dot d-gap"></span><b id="c-gap">{{ counts.gap }}</b> Gap</span>
  </div>
</div>

{% for sec in sections %}
  {% if sec.pillars is not empty %}
  <section class="sec">
    <div class="sec-h"><span class="n">{{ sec.no }}</span><h3>{{ sec.title }}</h3></div>
    <p class="sec-sub">{{ sec.sub }}</p>
    <div class="grid">
      {% for p in sec.pillars %}
      <div class="card{{ p.is_full ? ' full' : '' }}" data-pid="{{ p.pid }}" data-status="{{ p.status }}">
        <div class="card-top">
          <h4>{{ p.title }}</h4>
          <select class="status s-{{ p.status }}" data-pid="{{ p.pid }}" aria-label="Status for {{ p.title }}">
            {% for s in statuses %}<option value="{{ s.v }}"{{ s.v == p.status ? ' selected' : '' }}>{{ s.t }}</option>{% endfor %}
          </select>
        </div>
        {% if p.body is not empty or p.now_label is not empty %}
        <div class="now">
          {% if p.now_label is not empty %}<span class="lbl">{{ p.now_label }}</span>{% endif %}
          {% if p.body is not empty %}
            {% if p.is_quote %}<blockquote>"{{ p.body }}"</blockquote>{% else %}{{ p.body }}{% endif %}
          {% endif %}
        </div>
        {% endif %}
        {% if p.pills is not empty %}
        <div class="pills">
          {% for pill in p.pills %}<span class="pill{{ pill.cyan ? ' cyan' : '' }}">{{ pill.t }}</span>{% endfor %}
        </div>
        {% endif %}
        {% if p.decision is not empty %}
        <div class="decide"><span class="dl">{{ p.decide_label }}</span>{{ p.decision }}</div>
        {% endif %}
        <div class="notes">
          <label>Notes / drafts</label>
          <textarea data-pid="{{ p.pid }}" placeholder="Capture decisions and drafts...">{{ p.notes }}</textarea>
        </div>
        <div class="cfoot">
          <div class="edited" data-pid="{{ p.pid }}">
            {%- if p.last_edited_by is not empty -%}Last edited by {{ p.last_edited_by }} &middot; {{ p.last_edited_at }}{%- endif -%}
          </div>
          <button type="button" class="hbtn" data-pid="{{ p.pid }}" aria-expanded="false">History</button>
        </div>
        <div class="hist" data-pid="{{ p.pid }}" hidden></div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}
{% endfor %}

<button type="button" class="idock-toggle" id="idockToggle" aria-label="Open the Identity assistant">Ask Co-Intelligence</button>
<div class="idock" id="idock" aria-hidden="true">
  <div class="idock-head">
    <div><b>Identity assistant</b><small>Ask it to update a pillar. You approve every change.</small></div>
    <button type="button" class="idock-x" id="idockClose" aria-label="Close">&times;</button>
  </div>
  <div class="idock-stream" id="idockStream">
    <div class="imsg ai"><div class="av">CI</div><div class="ibub">Aanii. Tell me what to change on a pillar, for example: "set the Purpose pillar status to defined and add a note that we reviewed it." I will show you the exact change to approve before anything is written.</div></div>
  </div>
  <div class="idock-foot">
    <textarea id="idockInput" rows="1" placeholder="Ask the assistant to update a pillar..."></textarea>
    <button type="button" class="idock-send" id="idockSend">Send</button>
  </div>
</div>

<script>
(function(){
  var order=['defined','draft','work','gap'];
  var colorvar={defined:'var(--green)',draft:'var(--amber)',work:'var(--orange)',gap:'var(--grey)'};
  function applyCounts(counts){
    if(!counts) return;
    var total=counts.total||0;
    order.forEach(function(k){
      var b=document.getElementById('c-'+k); if(b) b.textContent=counts[k];
      var seg=document.querySelector('#bar span[data-k="'+k+'"]');
      if(seg) seg.style.width=(total?(counts[k]/total*100):0)+'%';
    });
  }
  function stamp(pid, by, at){
    var el=document.querySelector('.edited[data-pid="'+pid+'"]');
    if(el && by){ el.innerHTML='Last edited by '+by+' · '+at; el.classList.add('saveflash'); setTimeout(function(){el.classList.remove('saveflash');},900); }
  }
  function autosize(ta){
    // Grow to fit content up to the CSS max-height, then the well scrolls.
    ta.style.height='auto';
    ta.style.height=Math.min(ta.scrollHeight+2,340)+'px';
  }
  function save(body){
    return fetch('/anokii/identity/save',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'same-origin',body:JSON.stringify(body)})
      .then(function(r){ return r.json().catch(function(){return {ok:false};}); });
  }
  document.querySelectorAll('select.status').forEach(function(sel){
    sel.addEventListener('change',function(){
      var pid=sel.getAttribute('data-pid'), v=sel.value;
      var card=sel.closest('.card');
      card.setAttribute('data-status',v);
      sel.className='status s-'+v;
      save({pid:pid,status:v}).then(function(d){ if(d&&d.ok){ applyCounts(d.counts); stamp(pid,d.last_edited_by,d.last_edited_at); refreshIfOpen(pid); } });
    });
  });
  document.querySelectorAll('.notes textarea').forEach(function(ta){
    autosize(ta);
    var t=null;
    ta.addEventListener('input',function(){
      autosize(ta);
      clearTimeout(t);
      t=setTimeout(function(){
        var pid=ta.getAttribute('data-pid');
        save({pid:pid,notes:ta.value}).then(function(d){ if(d&&d.ok){ stamp(pid,d.last_edited_by,d.last_edited_at); refreshIfOpen(pid); } });
      },700);
    });
  });
  function renderHistory(panel, revisions){
    if(!revisions || !revisions.length){ panel.innerHTML='<p class="empty">No history yet.</p>'; return; }
    var html='<ol>';
    revisions.forEach(function(r){
      var c=colorvar[r.status]||'var(--grey)';
      html+='<li><span class="stat" style="background:'+c+'"></span><div>'
        +'<div class="sum">'+escapeHtml(r.summary||('Status '+r.status))+(r.is_current?' <span class="cur">(current)</span>':'')+'</div>'
        +'<div class="meta">'+escapeHtml(r.editor)+' · '+escapeHtml(r.when)+'</div>'
        +'</div></li>';
    });
    html+='</ol>';
    panel.innerHTML=html;
  }
  function escapeHtml(s){ return String(s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
  function loadHistory(pid){
    var panel=document.querySelector('.hist[data-pid="'+pid+'"]');
    if(!panel) return Promise.resolve();
    panel.innerHTML='<p class="empty">Loading...</p>';
    return fetch('/anokii/identity/'+encodeURIComponent(pid)+'/history',{credentials:'same-origin'})
      .then(function(r){ return r.json().catch(function(){return {ok:false};}); })
      .then(function(d){ renderHistory(panel, d&&d.ok?d.revisions:[]); });
  }
  function refreshIfOpen(pid){
    var panel=document.querySelector('.hist[data-pid="'+pid+'"]');
    if(panel && panel.classList.contains('open')){ loadHistory(pid); }
  }
  document.querySelectorAll('.hbtn').forEach(function(btn){
    btn.addEventListener('click',function(){
      var pid=btn.getAttribute('data-pid');
      var panel=document.querySelector('.hist[data-pid="'+pid+'"]');
      if(!panel) return;
      var open=panel.classList.toggle('open');
      panel.hidden=!open;
      btn.setAttribute('aria-expanded',open?'true':'false');
      btn.textContent=open?'Hide history':'History';
      if(open){ loadHistory(pid); }
    });
  });
})();

// Identity assistant chat dock: talks to the live agent endpoints
// (/anokii/cointelligence/send + /apply) with confirm-before-apply. On an
// applied change it reloads so the pillar grid + maturity bar reflect it.
(function(){
  var toggle=document.getElementById('idockToggle'), dock=document.getElementById('idock');
  var closeBtn=document.getElementById('idockClose'), stream=document.getElementById('idockStream');
  var input=document.getElementById('idockInput'), sendBtn=document.getElementById('idockSend');
  if(!toggle||!dock) return;
  var cid=0, busy=false, didApply=false;

  toggle.addEventListener('click', function(){ dock.classList.add('open'); dock.setAttribute('aria-hidden','false'); toggle.style.display='none'; input.focus(); });
  closeBtn.addEventListener('click', function(){ dock.classList.remove('open'); dock.setAttribute('aria-hidden','true'); toggle.style.display=''; });

  function esc(s){ return String(s==null?'':s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
  function fmt(t){ var h=esc(t).replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>'); return h.split(/\n\n+/).map(function(p){return '<p>'+p.replace(/\n/g,'<br>')+'</p>';}).join(''); }
  function fmtVal(v){ if(v===null||v===undefined||v==='') return '(none)'; if(typeof v==='object') return JSON.stringify(v); var s=String(v); return s.length>120?s.slice(0,117)+'...':s; }
  function addMsg(role){ var m=document.createElement('div'); m.className='imsg '+(role==='user'?'user':'ai'); var a=document.createElement('div'); a.className='av'; a.textContent=role==='user'?'YOU':'CI'; var b=document.createElement('div'); b.className='ibub'; m.appendChild(a); m.appendChild(b); stream.appendChild(m); stream.scrollTop=stream.scrollHeight; return b; }
  function frames(buf,on){ var parts=buf.split('\n\n'); var rest=parts.pop(); parts.forEach(function(bl){ var ev='message',data=''; bl.split('\n').forEach(function(l){ if(l.indexOf('event:')===0)ev=l.slice(6).trim(); else if(l.indexOf('data:')===0)data+=l.slice(5).trim(); }); if(data){ try{ on(ev,JSON.parse(data)); }catch(e){} } }); return rest; }

  function send(){ var q=(input.value||'').trim(); if(!q||busy) return; input.value=''; addMsg('user').textContent=q; var bub=addMsg('ai'); bub.innerHTML='<span class="iwork"><span class="d"></span>Thinking...</span>'; consume('/anokii/cointelligence/send',{question:q,conversation_id:cid},bub); }

  function consume(url,body,bub){
    busy=true; sendBtn.disabled=true; var raw='',proposed=false,started=false;
    fetch(url,{method:'POST',headers:{'Content-Type':'application/json','Accept':'text/event-stream'},credentials:'same-origin',body:JSON.stringify(body)})
    .then(function(r){ if(!r.ok||!r.body) throw new Error('bad'); var rd=r.body.getReader(),dec=new TextDecoder(),buf='';
      function pump(){ return rd.read().then(function(res){ if(res.done){ fin(); return; } buf+=dec.decode(res.value,{stream:true}); buf=frames(buf,function(ev,d){
        if(ev==='meta'){ if(d.conversation_id) cid=d.conversation_id; }
        else if(ev==='delta'){ if(!started){ bub.textContent=''; started=true; } raw+=d.text||''; bub.textContent=raw; stream.scrollTop=stream.scrollHeight; }
        else if(ev==='proposal'){ proposed=true; card(bub,raw,d); }
        else if(ev==='applied'){ if(d.ok) didApply=true; }
      }); return pump(); }); }
      function fin(){ if(!proposed){ bub.innerHTML=fmt(raw)||'<p>Done.</p>'; } busy=false; sendBtn.disabled=false; stream.scrollTop=stream.scrollHeight; if(didApply){ var n=addMsg('ai'); n.innerHTML='<span class="iwork"><span class="d"></span>Change applied. Refreshing the pillars...</span>'; setTimeout(function(){ location.reload(); },1400); } }
      return pump();
    }).catch(function(){ if(!proposed) bub.innerHTML='<p>Sorry, something went wrong. Please try again.</p>'; busy=false; sendBtn.disabled=false; });
  }

  function card(bub,lead,d){
    var h=lead?fmt(lead):''; h+='<div class="iprop'+(d.destructive?' danger':'')+'"><div class="ph">Proposed change'+(d.destructive?' (delete)':'')+'</div><div class="ps">'+esc(d.summary||'')+'</div>';
    if(d.diff&&d.diff.length){ h+='<ul class="pd">'; d.diff.forEach(function(x){ h+='<li><span class="f">'+esc(x.field)+'</span><span class="b">'+esc(fmtVal(x.before))+'</span><span>&rarr;</span><span class="a">'+esc(fmtVal(x.after))+'</span></li>'; }); h+='</ul>'; }
    h+='<div class="pact"><button class="ipb ok">Approve</button><button class="ipb no">Reject</button></div></div>';
    bub.innerHTML=h; busy=false; sendBtn.disabled=false;
    var c=bub.querySelector('.iprop');
    c.querySelector('.ok').addEventListener('click',function(){ decide(c,d.token,'approve'); });
    c.querySelector('.no').addEventListener('click',function(){ decide(c,d.token,'reject'); });
    stream.scrollTop=stream.scrollHeight;
  }
  function decide(c,token,decision){ if(busy) return; [].slice.call(c.querySelectorAll('.ipb')).forEach(function(b){ b.disabled=true; }); var bub=addMsg('ai'); bub.innerHTML='<span class="iwork"><span class="d"></span>'+(decision==='approve'?'Applying...':'Cancelling...')+'</span>'; consume('/anokii/cointelligence/apply',{token:token,decision:decision},bub); }

  sendBtn.addEventListener('click', send);
  input.addEventListener('keydown', function(e){ if(e.key==='Enter'&&!e.shiftKey){ e.preventDefault(); send(); } });
})();
</script>
{% endblock %}
