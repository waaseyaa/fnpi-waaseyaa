{% extends "base.html.twig" %}

{% block title %}Anokii · FNPI{% endblock %}
{% block description %}FNPI's private Anokii workspace.{% endblock %}
{% block robots %}noindex,nofollow{% endblock %}

{% block head_styles %}
  html,body{background:var(--bg)}
  .aapp{display:grid;grid-template-columns:248px 1fr;min-height:100vh}
  /* sidebar (FNPI dark) */
  .aside{background:#0a0e12;color:#fff;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;border-right:1px solid #1b2a30}
  .abrand{display:flex;align-items:center;gap:11px;padding:18px 16px 14px;border-bottom:1px solid #1b2a30}
  .abrand .lg{width:38px;height:38px;border-radius:9px;background:#fff;display:flex;align-items:center;justify-content:center;overflow:hidden;flex:0 0 auto}
  .abrand .lg img{width:100%;height:100%;object-fit:contain;padding:3px}
  .abrand .anm{font-family:"Anton",sans-serif;text-transform:uppercase;letter-spacing:.03em;font-size:19px;color:#fff;line-height:1}
  .abrand .asub{font-size:10px;color:#7fb8c6;font-family:"Oswald",sans-serif;letter-spacing:.02em;margin-top:4px;line-height:1.35}
  .anav{padding:8px 10px;flex:1;overflow:auto}
  .agroup{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:#5c6b72;font-family:"Oswald",sans-serif;font-weight:600;padding:14px 12px 6px}
  .anavlink{display:flex;align-items:center;gap:11px;padding:9px 12px;border-radius:9px;color:#aebbc2;font-size:14px;margin:2px 0;font-family:"Oswald",sans-serif;letter-spacing:.01em;transition:background .12s,color .12s}
  .anavlink svg{width:18px;height:18px;flex:0 0 auto;opacity:.9}
  .anavlink:hover{background:rgba(255,255,255,.06);color:#fff}
  .anavlink.on{background:var(--cyan2);color:#fff;box-shadow:0 2px 12px rgba(31,182,214,.32)}
  .anavlink.on svg{opacity:1}
  .anavlink .abadge{margin-left:auto;font-size:9px;font-weight:700;border-radius:20px;padding:2px 7px;letter-spacing:.06em;text-transform:uppercase;font-family:"Oswald",sans-serif;background:#26323a;color:#7fd6e8}
  .atag{font-size:11px;color:#8b969c;padding:14px 16px;border-top:1px solid #1b2a30;line-height:1.5;font-family:"Oswald",sans-serif}
  .atag b{color:#fff;font-weight:600}
  /* main + topbar */
  .amain{display:flex;flex-direction:column;min-width:0}
  .atop{display:flex;align-items:center;gap:16px;padding:11px 24px;background:#fff;border-bottom:1px solid var(--line);position:sticky;top:0;z-index:30}
  .asearch{flex:1;max-width:520px;position:relative}
  .asearch input{width:100%;border:1px solid var(--line);background:var(--bg);border-radius:9px;padding:9px 12px 9px 36px;font:inherit;font-size:14px;outline:none;color:var(--ink)}
  .asearch input:focus{border-color:var(--cyan);background:#fff;box-shadow:0 0 0 3px rgba(31,182,214,.14)}
  .asearch .si{position:absolute;left:11px;top:9px;width:17px;height:17px;color:var(--muted)}
  .asr-box{position:absolute;top:44px;left:0;right:0;background:#fff;border:1px solid var(--line);border-radius:10px;box-shadow:0 10px 34px rgba(10,14,18,.16);padding:6px;display:none;z-index:60}
  .asr-box.open{display:block}
  .asr{display:flex;gap:10px;align-items:center;padding:8px 10px;border-radius:8px;color:var(--ink);cursor:pointer;text-decoration:none}
  .asr:hover{background:var(--bg)}
  .asr .ic{width:28px;height:28px;border-radius:7px;background:var(--bg);display:flex;align-items:center;justify-content:center;color:var(--cyan2);flex:0 0 auto}
  .asr .ic svg{width:16px;height:16px}
  .asr b{font-size:13.5px;font-weight:600}
  .asr small{color:var(--muted);margin-left:auto;font-family:"Oswald",sans-serif;text-transform:uppercase;font-size:10px;letter-spacing:.06em}
  .asr-empty{padding:10px 12px;color:var(--muted);font-size:13px}
  .aspacer{flex:1}
  .abell-wrap{position:relative}
  .aiconbtn{position:relative;width:38px;height:38px;border-radius:9px;border:1px solid var(--line);background:#fff;display:flex;align-items:center;justify-content:center;color:var(--ink);cursor:pointer}
  .aiconbtn:hover{background:var(--bg)} .aiconbtn svg{width:19px;height:19px}
  .abell-count{position:absolute;top:-5px;right:-5px;background:var(--cyan2);color:#fff;font-size:10px;font-weight:700;border-radius:20px;min-width:17px;height:17px;display:flex;align-items:center;justify-content:center;padding:0 4px;font-family:"Oswald",sans-serif}
  .apop{position:absolute;top:48px;right:0;width:320px;background:#fff;border:1px solid var(--line);border-radius:12px;box-shadow:0 10px 34px rgba(10,14,18,.16);z-index:70;display:none;overflow:hidden}
  .apop.open{display:block}
  .apop .pvh{padding:12px 15px;border-bottom:1px solid var(--line);font-family:"Oswald",sans-serif;font-weight:600;text-transform:uppercase;letter-spacing:.06em;font-size:12px;color:var(--ink)}
  .apop .nrow{display:flex;gap:11px;padding:11px 15px;border-bottom:1px solid var(--line)} .apop .nrow:last-child{border-bottom:none}
  .apop .nic{width:28px;height:28px;border-radius:7px;background:#e3f4f8;color:var(--cyan2);display:flex;align-items:center;justify-content:center;flex:0 0 auto} .apop .nic svg{width:15px;height:15px}
  .apop .ntext b{font-size:13px;color:var(--ink);display:block} .apop .ntext small{color:var(--muted);font-size:11.5px}
  .auser{display:flex;align-items:center;gap:10px;padding:4px 9px 4px 4px;border-radius:30px;border:1px solid var(--line);background:#fff}
  .aavatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--cyan2),var(--cyan));color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12.5px;font-family:"Oswald",sans-serif;flex:0 0 auto}
  .auinfo{line-height:1.15} .auinfo b{font-size:13px;color:var(--ink);font-weight:600} .auinfo small{display:block;color:var(--muted);font-size:11px}
  .acontent{padding:26px;flex:1;min-width:0}
  .afoot{padding:13px 24px;border-top:1px solid var(--line);background:#fff;color:var(--muted);font-size:12px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .afoot .lk{width:14px;height:14px;color:var(--cyan2);flex:0 0 auto}
  .afoot .amig{margin-left:auto;font-family:"Oswald",sans-serif;color:var(--cyan2)}
  /* page head reused by tools */
  .ahead{margin:0 0 18px}
  .ahead .ey{font-family:"Oswald",sans-serif;font-size:12px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--cyan2);margin:0 0 6px}
  .ahead h1{font-family:"Anton",sans-serif;text-transform:uppercase;letter-spacing:.01em;font-size:34px;margin:0;color:var(--ink)}
  .ahead p.sub{color:var(--muted);margin:8px 0 0;max-width:72ch}
  @media(max-width:880px){.aapp{grid-template-columns:1fr}.aside{position:static;height:auto}.asub{display:none}}
  {% block anokii_styles %}{% endblock %}
{% endblock %}

{% block topnav %}{% endblock %}
{% block sitefooter %}{% endblock %}

{% block content %}
<div class="aapp">
  <aside class="aside">
    <a class="abrand" href="/anokii" style="text-decoration:none">
      <span class="lg"><img src="/img/fnpi-wolf.png" alt="FNPI"></span>
      <span><span class="anm">Anokii</span><br><span class="asub">Sovereign workspace · First Nations Procurement Inc.</span></span>
    </a>
    <nav class="anav">
      {% set grp = '' %}
      {% for m in modules %}
        {% if m.group != grp %}<div class="agroup">{{ m.group }}</div>{% set grp = m.group %}{% endif %}
        <a class="anavlink{{ nav_active == m.id ? ' on' : '' }}" href="{{ m.href }}" data-label="{{ m.label }}" data-soon="{{ m.live ? '0' : '1' }}">
          <svg viewBox="0 0 24 24">{{ m.icon|raw }}</svg><span>{{ m.label }}</span>
          {% if m.badge %}<span class="abadge">{{ m.badge }}</span>{% endif %}
        </a>
      {% endfor %}
    </nav>
    <div class="atag">One platform the Nation owns and controls. <b>Sovereign by design, hosted in Canada.</b></div>
  </aside>

  <div class="amain">
    <header class="atop">
      <div class="asearch">
        <svg class="si" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/><path d="m20 20-3-3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        <input id="anokiiSearch" placeholder="Search Anokii modules&hellip;" autocomplete="off">
        <div class="asr-box" id="anokiiSearchResults"></div>
      </div>
      <div class="aspacer"></div>
      <div class="abell-wrap">
        <button class="aiconbtn" id="anokiiBell" title="Notifications" type="button">
          <svg viewBox="0 0 24 24" fill="none"><path d="M6 9a6 6 0 0 1 12 0c0 5 2 6 2 6H4s2-1 2-6Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M10 19a2 2 0 0 0 4 0" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
          <span class="abell-count">2</span>
        </button>
        <div class="apop" id="anokiiPop">
          <div class="pvh">Notifications</div>
          <div class="nrow"><span class="nic"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l1.9 5.6L19.5 10l-5.6 1.9L12 17l-1.9-5.1L4.5 10l5.6-1.4L12 3Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg></span><span class="ntext"><b>Welcome to Anokii</b><small>FNPI's sovereign workspace is live.</small></span></div>
          <div class="nrow"><span class="nic"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="9" r="3" stroke="currentColor" stroke-width="1.6"/><path d="M5 20c1-3 4-4.5 7-4.5s6 1.5 7 4.5" stroke="currentColor" stroke-width="1.6"/></svg></span><span class="ntext"><b>Identity Workspace is ready</b><small>Settle FNPI's brand pillars together.</small></span></div>
        </div>
      </div>
      <div class="auser" title="Signed in">
        <div class="aavatar">{{ user_initials }}</div>
        <div class="auinfo"><b>{{ user_label }}</b><small>{{ user_role }}</small></div>
      </div>
      <a class="aiconbtn" href="/anokii/logout" title="Sign out" style="text-decoration:none">
        <svg viewBox="0 0 24 24" fill="none"><path d="M14 7V5a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M10 12h10m0 0-3-3m3 3-3 3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </header>

    <main class="acontent">{% block anokii_content %}{% endblock %}</main>

    <footer class="afoot">
      <svg class="lk" viewBox="0 0 24 24" fill="none"><rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.7"/><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.7"/></svg>
      <span>FNPI's own Anokii on the Waaseyaa platform · Sovereign at rest · Hosted in Canada</span>
      <span class="amig">Anokii · Anishinaabemowin for "she/he works"</span>
    </footer>
  </div>
</div>

<script>
(function(){
  // Search: client-side filter over the sidebar module links.
  var input=document.getElementById('anokiiSearch'), box=document.getElementById('anokiiSearchResults');
  var links=[].slice.call(document.querySelectorAll('.anavlink'));
  var index=links.map(function(a){ return {label:a.getAttribute('data-label')||a.textContent.trim(), href:a.getAttribute('href'), soon:a.getAttribute('data-soon')==='1', icon:(a.querySelector('svg')||{}).outerHTML||''}; });
  function render(q){
    var ql=q.trim().toLowerCase();
    if(!ql){ box.classList.remove('open'); box.innerHTML=''; return; }
    var hits=index.filter(function(m){ return m.label.toLowerCase().indexOf(ql)>-1; });
    box.innerHTML = hits.length ? hits.map(function(m){
      return '<a class="asr" href="'+m.href+'"><span class="ic">'+m.icon+'</span><b>'+m.label+'</b>'+(m.soon?'<small>Soon</small>':'<small>Open</small>')+'</a>';
    }).join('') : '<div class="asr-empty">No modules match &ldquo;'+q.replace(/[<>&]/g,'')+'&rdquo;.</div>';
    box.classList.add('open');
  }
  if(input){ input.addEventListener('input',function(){ render(input.value); }); }
  // Bell popover toggle.
  var bell=document.getElementById('anokiiBell'), pop=document.getElementById('anokiiPop');
  if(bell){ bell.addEventListener('click',function(e){ e.stopPropagation(); pop.classList.toggle('open'); }); }
  // Outside click closes both.
  document.addEventListener('click',function(e){
    if(!e.target.closest('.asearch')){ box.classList.remove('open'); }
    if(!e.target.closest('.abell-wrap')){ pop.classList.remove('open'); }
  });
})();
</script>
{% endblock %}
