{% extends "base.html.twig" %}

{% block title %}Set your password · Anokii · FNPI{% endblock %}
{% block robots %}noindex,nofollow{% endblock %}

{% block head_styles %}
  body{background:var(--dark)}
  .authpage{display:flex;align-items:center;justify-content:center;padding:48px 20px;min-height:100vh}
  .authcard{width:100%;max-width:400px;background:#fff;border:1px solid var(--line);border-radius:10px;padding:30px 28px}
  .authcard .brand{display:flex;align-items:center;gap:10px;margin-bottom:18px}
  .authcard .brand img{height:34px}
  .authcard .brand .nm{font-family:"Anton",sans-serif;text-transform:uppercase;letter-spacing:.04em;font-size:20px;color:var(--ink)}
  .authcard h1{font-family:"Anton",sans-serif;text-transform:uppercase;font-size:23px;margin:0 0 4px;color:var(--ink)}
  .authcard .sub{color:var(--muted);font-size:13.5px;margin:0 0 20px}
  .fld{margin-bottom:13px}
  .fld label{display:block;font-family:"Oswald",sans-serif;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:5px}
  .fld input{width:100%;border:1px solid var(--line);border-radius:5px;padding:11px 12px;font:inherit;font-size:14px;background:#fcfcfa}
  .fld input:focus{outline:2px solid #e3f4f8;border-color:var(--cyan)}
  .abtn{width:100%;background:var(--cyan2);color:#fff;border:none;border-radius:5px;padding:12px;font-family:"Oswald",sans-serif;font-weight:600;letter-spacing:.08em;text-transform:uppercase;font-size:13px;cursor:pointer}
  .abtn:hover{background:#0f7488}
  .note{font-size:12px;color:var(--muted);margin-top:6px}
  .err{display:none;background:#fdecea;color:#a4291c;border-radius:5px;padding:9px 11px;font-size:13px;margin-bottom:14px}
  .err.show{display:block}
  .invalid{background:#fdecea;color:#a4291c;border-radius:6px;padding:14px 16px;font-size:14px}
{% endblock %}

{% block topnav %}{% endblock %}
{% block sitefooter %}{% endblock %}

{% block content %}
<div class="authpage"><div class="authcard">
  <div class="brand"><img src="/img/fnpi-wolf.png" alt="FNPI"><span class="nm">Anokii</span></div>
  {% if valid %}
    <h1>Set your password</h1>
    <p class="sub">Setting the password for <b>{{ email }}</b>. Choose something only you know.</p>
    <div class="err" id="err"></div>
    <form id="spForm">
      <div class="fld"><label for="pw">New password</label><input type="password" id="pw" required autocomplete="new-password" minlength="10"></div>
      <div class="fld"><label for="pw2">Confirm password</label><input type="password" id="pw2" required autocomplete="new-password" minlength="10"></div>
      <button class="abtn" type="submit">Set password and continue</button>
      <p class="note">At least 10 characters.</p>
    </form>
  {% else %}
    <h1>Link not valid</h1>
    <div class="invalid">This set-password link is invalid or has already been used. Ask for a fresh invite link.</div>
  {% endif %}
</div></div>

{% if valid %}
<script>
(function(){
  var f=document.getElementById('spForm'), err=document.getElementById('err');
  var token={{ token|json_encode|raw }};
  f.addEventListener('submit', function(e){
    e.preventDefault();
    err.classList.remove('show');
    var pw=document.getElementById('pw').value, pw2=document.getElementById('pw2').value;
    if(pw.length<10){ err.textContent='Password must be at least 10 characters.'; err.classList.add('show'); return; }
    if(pw!==pw2){ err.textContent='The two passwords do not match.'; err.classList.add('show'); return; }
    fetch('/anokii/set-password', {
      method:'POST', headers:{'Content-Type':'application/json'}, credentials:'same-origin',
      body: JSON.stringify({token: token, password: pw})
    }).then(function(r){ return r.json().catch(function(){return {ok:false,error:'Something went wrong.'};}); })
      .then(function(d){
        if(d && d.ok){ window.location = d.redirect || '/anokii/login'; }
        else { err.textContent=(d && d.error)||'Could not set password.'; err.classList.add('show'); }
      }).catch(function(){ err.textContent='Network error. Try again.'; err.classList.add('show'); });
  });
})();
</script>
{% endif %}
{% endblock %}
