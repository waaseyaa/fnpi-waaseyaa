{% extends "anokii/_shell.html.twig" %}

{% block anokii_styles %}
  :root{ --card-shadow:0 1px 3px rgba(10,14,18,.05),0 8px 24px rgba(10,14,18,.06); }
  .btn{font-family:"Oswald",sans-serif;font-size:13px;letter-spacing:.02em;border-radius:8px;padding:8px 13px;border:1px solid var(--line);background:#fff;color:var(--ink);cursor:pointer;display:inline-flex;align-items:center;gap:7px;text-decoration:none}
  .btn:hover{background:var(--bg)} .btn svg{width:15px;height:15px}
  .btn.primary{background:var(--cyan2);border-color:var(--cyan2);color:#fff} .btn.primary:hover{background:var(--cyan)}
  .btn.sm{padding:5px 10px;font-size:12px}
  .dback{display:inline-flex;align-items:center;gap:6px;color:var(--muted);font-size:13px;text-decoration:none;margin-bottom:12px}
  .dback:hover{color:var(--ink)} .dback svg{width:15px;height:15px}
  /* two-column Data Room layout: preview left, history + notes right */
  .two{display:grid;grid-template-columns:1.5fr 1fr;gap:20px;align-items:start}
  @media(max-width:1000px){.two{grid-template-columns:1fr}}
  .card{background:#fff;border:1px solid var(--line);border-radius:14px;box-shadow:var(--card-shadow);overflow:hidden}
  .card .ch{display:flex;align-items:center;gap:10px;padding:13px 16px;border-bottom:1px solid var(--line)}
  .card .ch b{font-family:"Oswald",sans-serif;font-weight:600;text-transform:uppercase;letter-spacing:.06em;font-size:12.5px;color:var(--ink)}
  .card .ch .sp{flex:1}
  /* preview */
  .pv{width:100%;height:72vh;min-height:520px;border:0;display:block;background:var(--bg)}
  .pv-none{padding:48px 24px;text-align:center;color:var(--muted)}
  .pv-none b{display:block;color:var(--ink);font-family:"Oswald",sans-serif;font-size:15px;margin-bottom:6px}
  .pv-cap{padding:9px 16px;border-top:1px solid var(--line);font-size:12px;color:var(--muted);display:flex;align-items:center;gap:8px}
  .pv-cap b{color:var(--ink)}
  /* version history */
  .vrow{display:flex;gap:12px;padding:13px 16px;border-bottom:1px solid var(--line)}
  .vrow:last-child{border-bottom:none}
  .vrow.cur{background:var(--cyan-soft,#e3f4f8)}
  .vdot{width:30px;height:30px;border-radius:50%;background:var(--bg);color:var(--cyan2);display:flex;align-items:center;justify-content:center;font-family:"Oswald",sans-serif;font-weight:700;font-size:12px;flex:0 0 auto;border:1px solid var(--line)}
  .vrow.cur .vdot{background:var(--cyan2);color:#fff;border-color:var(--cyan2)}
  .vmeta{flex:1;min-width:0}
  .vmeta b{display:block;color:var(--ink);font-size:14px}
  .vmeta small{color:var(--muted);font-size:12px;display:block;margin-top:1px}
  .vcur{font-family:"Oswald",sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--cyan2);font-weight:700;margin-top:5px;display:inline-block}
  .vacts{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}
  /* notes thread */
  .nadd{display:flex;flex-direction:column;gap:8px;padding:14px 16px;border-bottom:1px solid var(--line)}
  .nadd textarea{width:100%;border:1px solid var(--line);border-radius:9px;padding:10px 12px;font:inherit;font-size:14px;resize:vertical;min-height:64px;outline:none;color:var(--ink)}
  .nadd textarea:focus{border-color:var(--cyan);box-shadow:0 0 0 3px rgba(31,182,214,.14)}
  .nadd .row{display:flex;align-items:center;gap:8px} .nadd .row .sp{flex:1}
  .note{display:flex;gap:11px;padding:14px 16px;border-bottom:1px solid var(--line)}
  .note:last-child{border-bottom:none}
  .navatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--cyan2),var(--cyan));color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;font-family:"Oswald",sans-serif;flex:0 0 auto}
  .nbody{flex:1;min-width:0}
  .nbody .nh{display:flex;align-items:baseline;gap:8px}
  .nbody .nh b{color:var(--ink);font-size:14px} .nbody .nh small{color:var(--muted);font-size:11.5px}
  .nbody p{margin:5px 0 0;color:var(--ink);font-size:14px;line-height:1.55;white-space:pre-wrap;word-break:break-word}
  .nempty{padding:22px 16px;color:var(--muted);font-size:13.5px;text-align:center}
  .dtoast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--ink);color:#fff;padding:11px 18px;border-radius:10px;font-size:13.5px;opacity:0;pointer-events:none;transition:all .2s;z-index:120}
  .dtoast.show{opacity:1;transform:translateX(-50%) translateY(0)}
{% endblock %}

{% block anokii_content %}
<a class="dback" href="/anokii/documents"><svg viewBox="0 0 24 24" fill="none"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>All documents</a>

<div class="ahead" style="margin-bottom:16px">
  <p class="ey">{{ doc.folder ?: 'Document' }}</p>
  <h1 style="font-size:28px">{{ doc.title }}</h1>
  <p class="sub" style="margin-top:6px">Owner {{ doc.owner_label }} &middot; current version {{ doc.current_label }} by {{ doc.current_author }} &middot; updated {{ doc.updated }}</p>
</div>

<div class="two">
  {# ---- LEFT: preview ---- #}
  <div class="card">
    <div class="ch">
      <b>Preview</b><span class="sp"></span>
      <a class="btn sm" id="srcBtn" href="{{ doc.source_url }}">Download .docx</a>
    </div>
    {% if doc.has_preview %}
      <iframe class="pv" id="pv" src="{{ doc.preview_url }}" title="Document preview"></iframe>
    {% else %}
      <iframe class="pv" id="pv" src="" title="Document preview" style="display:none"></iframe>
      <div class="pv-none" id="pvNone"><b>No preview yet</b><span>This version has no PDF preview. Download the .docx to read it; new uploads convert to a preview automatically.</span></div>
    {% endif %}
    <div class="pv-cap">Showing <b id="pvLabel">{{ doc.current_label }}</b> &middot; rendered inline, sovereign at rest</div>
  </div>

  {# ---- RIGHT: history (top) + notes (bottom) ---- #}
  <div style="display:flex;flex-direction:column;gap:20px">
    <div class="card">
      <div class="ch">
        <b>Version history</b><span class="sp"></span>
        <button class="btn primary sm" id="newVerBtn" type="button">Upload new version</button>
        <input type="file" id="verFile" accept=".docx,.pdf,.doc" hidden>
      </div>
      {% for v in versions %}
        <div class="vrow{{ v.is_current ? ' cur' : '' }}">
          <span class="vdot">v{{ v.vid }}</span>
          <div class="vmeta">
            <b>{{ v.label }}</b>
            <small>{{ v.author }} &middot; {{ v.created }}</small>
            {% if v.is_current %}<span class="vcur">Current version</span>{% endif %}
            <div class="vacts">
              {% if v.has_preview %}<button class="btn sm" type="button" data-preview="{{ v.preview_url }}" data-label="{{ v.label }}">View</button>{% endif %}
              <a class="btn sm" href="{{ v.source_url }}">Download</a>
              {% if not v.is_current %}
                <button class="btn sm" type="button" data-setcurrent="{{ v.vid }}">Make current</button>
                <button class="btn sm" type="button" data-rollback="{{ v.vid }}">Roll back here</button>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="card">
      <div class="ch"><b>Notes</b></div>
      <div class="nadd">
        <textarea id="noteBody" placeholder="Add a note for the team..."></textarea>
        <div class="row"><span class="sp"></span><button class="btn primary sm" id="noteBtn" type="button">Post note</button></div>
      </div>
      <div id="noteList">
        {% for n in notes %}
          <div class="note">
            <span class="navatar">{{ n.author|slice(0,2)|upper }}</span>
            <div class="nbody"><div class="nh"><b>{{ n.author }}</b><small>{{ n.created }}</small></div><p>{{ n.body }}</p></div>
          </div>
        {% endfor %}
        <div class="nempty" id="noteEmpty" style="{{ notes is empty ? '' : 'display:none' }}">No notes yet. Start the discussion.</div>
      </div>
    </div>
  </div>
</div>

<div class="dtoast" id="toast"></div>

<script>
(function(){
  var UUID = {{ doc.uuid|json_encode|raw }};
  function xsrf(){ return (document.cookie.match(/(?:^|;\s*)XSRF-TOKEN=([^;]+)/)||[])[1] || ''; }
  function toast(m){ var t=document.getElementById('toast'); t.textContent=m; t.classList.add('show'); clearTimeout(t._h); t._h=setTimeout(function(){t.classList.remove('show');},2600); }
  function esc(s){ return String(s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];}); }
  function postJson(url, payload){
    return fetch(url,{method:'POST',headers:{'Content-Type':'application/json','X-XSRF-TOKEN':xsrf()},credentials:'same-origin',body:JSON.stringify(payload||{})})
      .then(function(r){ return r.json().catch(function(){return {ok:false};}); });
  }

  // Preview any version in the left pane.
  document.addEventListener('click', function(e){
    var v=e.target.closest('[data-preview]'); if(!v) return;
    var pv=document.getElementById('pv'), none=document.getElementById('pvNone');
    pv.src=v.getAttribute('data-preview'); pv.style.display='block'; if(none) none.style.display='none';
    document.getElementById('pvLabel').textContent=v.getAttribute('data-label');
    document.getElementById('srcBtn').setAttribute('href', v.getAttribute('data-preview').replace('/preview','/source')+'?dl=1');
  });

  // Make current / roll back.
  document.addEventListener('click', function(e){
    var sc=e.target.closest('[data-setcurrent]'), rb=e.target.closest('[data-rollback]');
    if(sc){ if(!confirm('Make this the current version?')) return; toast('Switching version...');
      postJson('/anokii/documents/'+encodeURIComponent(UUID)+'/set-current',{vid:parseInt(sc.getAttribute('data-setcurrent'),10)})
        .then(function(r){ if(r.ok){ window.location.reload(); } else { toast(r.error||'Could not switch.'); } }); }
    if(rb){ if(!confirm('Roll back to this version? This records a new version at the top of history.')) return; toast('Rolling back...');
      postJson('/anokii/documents/'+encodeURIComponent(UUID)+'/rollback',{vid:parseInt(rb.getAttribute('data-rollback'),10)})
        .then(function(r){ if(r.ok){ window.location.reload(); } else { toast(r.error||'Could not roll back.'); } }); }
  });

  // Upload a new version.
  var verFile=document.getElementById('verFile');
  document.getElementById('newVerBtn').addEventListener('click', function(){ verFile.click(); });
  verFile.addEventListener('change', function(){
    var file=verFile.files[0]; if(!file) return;
    var label=prompt('Short label for this version (e.g. "Branded draft"):', file.name.replace(/\.[^.]+$/,'')); if(label===null) return;
    var fd=new FormData(); fd.append('file', file); fd.append('version_label', label.trim());
    toast('Uploading '+file.name+' and converting preview...');
    var xhr=new XMLHttpRequest(); xhr.open('POST','/anokii/documents/'+encodeURIComponent(UUID)+'/version');
    var t=xsrf(); if(t){ xhr.setRequestHeader('X-XSRF-TOKEN', t); }
    xhr.onload=function(){ var r={}; try{ r=JSON.parse(xhr.responseText); }catch(_){}
      if(xhr.status>=200&&xhr.status<300&&r.ok){ window.location.reload(); } else { toast(r.error||'Upload failed.'); } };
    xhr.onerror=function(){ toast('Upload failed.'); };
    xhr.send(fd);
  });

  // Post a note.
  document.getElementById('noteBtn').addEventListener('click', function(){
    var ta=document.getElementById('noteBody'), body=ta.value.trim(); if(!body){ toast('Write a note first.'); return; }
    postJson('/anokii/documents/'+encodeURIComponent(UUID)+'/note',{body:body}).then(function(r){
      if(r.ok&&r.note){ ta.value='';
        var n=r.note, html='<div class="note"><span class="navatar">'+esc(n.author).slice(0,2).toUpperCase()+'</span>'+
          '<div class="nbody"><div class="nh"><b>'+esc(n.author)+'</b><small>'+esc(n.created)+'</small></div><p>'+esc(n.body)+'</p></div></div>';
        var list=document.getElementById('noteList'); var empty=document.getElementById('noteEmpty'); if(empty) empty.style.display='none';
        list.insertAdjacentHTML('afterbegin', html); toast('Note posted.');
      } else { toast(r.error||'Could not post note.'); }
    });
  });
})();
</script>
{% endblock %}
