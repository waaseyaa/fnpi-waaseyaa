{% extends "anokii/_fnpi_base.html.twig" %}

{% block anokii_styles %}
  :root{ --card-shadow:0 1px 3px rgba(10,14,18,.05),0 8px 24px rgba(10,14,18,.06); }
  .dbar{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:16px}
  .dspacer{flex:1}
  .btn{font-family:"Oswald",sans-serif;font-size:13.5px;letter-spacing:.02em;border-radius:9px;padding:9px 15px;border:1px solid var(--line);background:#fff;color:var(--ink);cursor:pointer;display:inline-flex;align-items:center;gap:8px;text-decoration:none}
  .btn:hover{background:var(--bg)} .btn svg{width:16px;height:16px}
  .btn.primary{background:var(--cyan2);border-color:var(--cyan2);color:#fff} .btn.primary:hover{background:var(--cyan)}
  .dlist{background:#fff;border:1px solid var(--line);border-radius:14px;box-shadow:var(--card-shadow);overflow:hidden}
  .drow{display:flex;align-items:center;gap:13px;padding:14px 16px;border-bottom:1px solid var(--line);cursor:pointer;transition:background .1s;text-decoration:none;color:inherit}
  .drow:last-child{border-bottom:none} .drow:hover{background:var(--bg)}
  .dic{width:38px;height:38px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex:0 0 auto;background:#e8effd;color:#3a6cd6}
  .dic svg{width:20px;height:20px}
  .dmeta{flex:1;min-width:0}
  .dmeta b{display:block;font-weight:600;color:var(--ink);font-size:15px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .dmeta small{color:var(--muted);font-size:12.5px}
  .dver{flex:0 0 auto;font-family:"Oswald",sans-serif;font-size:11px;letter-spacing:.04em;text-transform:uppercase;color:var(--cyan2);background:var(--cyan-soft,#e3f4f8);border-radius:20px;padding:3px 10px}
  .dfolder{flex:0 0 auto;font-family:"Oswald",sans-serif;font-size:11px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted)}
  .ddate{flex:0 0 auto;width:120px;font-size:12.5px;color:var(--muted);text-align:right}
  @media(max-width:760px){.dfolder,.ddate{display:none}}
  .dempty{background:#fff;border:1px dashed var(--line);border-radius:14px;padding:48px 24px;text-align:center;color:var(--muted)}
  .dempty b{display:block;color:var(--ink);font-family:"Oswald",sans-serif;font-size:16px;margin-bottom:4px}
  .dtoast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--ink);color:#fff;padding:11px 18px;border-radius:10px;font-size:13.5px;opacity:0;pointer-events:none;transition:all .2s;z-index:120}
  .dtoast.show{opacity:1;transform:translateX(-50%) translateY(0)}
{% endblock %}

{% block anokii_content %}
<div class="ahead">
  <p class="ey">Documents</p>
  <h1>Documents</h1>
  <p class="sub">Preview a document, keep every version with full history, and discuss it in one place instead of email and DM. Each version is a Waaseyaa revision; rolling back is first-class. Stored on FNPI's own infrastructure, sovereign at rest.</p>
</div>

<div class="dbar">
  <div class="dspacer"></div>
  <input type="text" id="newTitle" placeholder="Document title (optional)" style="border:1px solid var(--line);border-radius:9px;padding:9px 12px;font:inherit;font-size:13.5px;width:230px">
  <input type="text" id="newFolder" placeholder="Folder" style="border:1px solid var(--line);border-radius:9px;padding:9px 12px;font:inherit;font-size:13.5px;width:130px">
  <button class="btn primary" id="newBtn" type="button">
    <svg viewBox="0 0 24 24" fill="none"><path d="M12 16V5m0 0L8 9m4-4 4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
    New document
  </button>
  <input type="file" id="newFile" accept=".docx,.pdf,.doc" hidden>
</div>

<div class="dlist">
  {% for d in documents %}
    <a class="drow" href="{{ d.href }}">
      <span class="dic"><svg viewBox="0 0 24 24"><path d="M7 3h7l4 4v14a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linejoin="round"/><path d="M14 3v4h4" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linejoin="round"/></svg></span>
      <span class="dmeta">
        <b>{{ d.title }}</b>
        <small>{{ d.owner_label }} &middot; current: {{ d.current_label }} &middot; {{ d.current_author }}</small>
      </span>
      {% if d.folder %}<span class="dfolder">{{ d.folder }}</span>{% endif %}
      <span class="dver">v{{ d.current_vid }}</span>
      <span class="ddate">{{ d.updated }}</span>
    </a>
  {% endfor %}
  {% if documents is empty %}
    <div class="dempty"><b>No documents yet</b><span>Upload a .docx to start a document with version history and notes.</span></div>
  {% endif %}
</div>

<div class="dtoast" id="toast"></div>

<script>
(function(){
  function xsrf(){ return (document.cookie.match(/(?:^|;\s*)XSRF-TOKEN=([^;]+)/)||[])[1] || ''; }
  function toast(m){ var t=document.getElementById('toast'); t.textContent=m; t.classList.add('show'); clearTimeout(t._h); t._h=setTimeout(function(){t.classList.remove('show');},2600); }
  var fileInput=document.getElementById('newFile');
  document.getElementById('newBtn').addEventListener('click', function(){ fileInput.click(); });
  fileInput.addEventListener('change', function(){
    var file=fileInput.files[0]; if(!file) return;
    var fd=new FormData(); fd.append('file', file);
    fd.append('title', document.getElementById('newTitle').value.trim());
    fd.append('folder', document.getElementById('newFolder').value.trim());
    toast('Uploading ' + file.name + '...');
    var xhr=new XMLHttpRequest(); xhr.open('POST','/admin/anokii/documents/create');
    var t=xsrf(); if(t){ xhr.setRequestHeader('X-XSRF-TOKEN', t); }
    xhr.onload=function(){ var r={}; try{ r=JSON.parse(xhr.responseText); }catch(_){}
      if(xhr.status>=200&&xhr.status<300&&r.ok){ window.location=r.redirect; } else { toast(r.error||'Upload failed.'); } };
    xhr.onerror=function(){ toast('Upload failed.'); };
    xhr.send(fd);
  });
})();
</script>
{% endblock %}
