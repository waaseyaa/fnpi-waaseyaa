{% extends "anokii/_fnpi_base.html.twig" %}

{% block anokii_styles %}
  .soonwrap{background:#fff;border:1px solid var(--line);border-radius:14px;padding:48px 40px;text-align:center;max-width:640px;margin:10px auto}
  .soonwrap .ic{width:64px;height:64px;border-radius:16px;background:#0a0e12;color:#7fd6e8;display:flex;align-items:center;justify-content:center;margin:0 auto 18px}
  .soonwrap .ic svg{width:32px;height:32px}
  .soonwrap .pill{display:inline-block;font-family:"Oswald",sans-serif;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:#7a4e1d;background:#f3e9da;border-radius:3px;padding:3px 10px;margin-bottom:14px}
  .soonwrap h1{font-family:"Anton",sans-serif;text-transform:uppercase;letter-spacing:.01em;font-size:32px;color:var(--ink);margin:0 0 10px}
  .soonwrap p{color:var(--muted);margin:0 auto 22px;max-width:48ch}
  .soonwrap .btn{display:inline-block;background:var(--cyan2);color:#fff;border-radius:5px;padding:11px 20px;font-family:"Oswald",sans-serif;font-weight:600;letter-spacing:.08em;text-transform:uppercase;font-size:12.5px}
  .soonwrap .btn:hover{background:#0f7488}
{% endblock %}

{% block anokii_content %}
<div class="soonwrap">
  <div class="ic"><svg viewBox="0 0 24 24">{{ module.icon|raw }}</svg></div>
  <span class="pill">Coming soon</span>
  <h1>{{ module.label }}</h1>
  <p>{{ module.desc }} This module is part of the Anokii roadmap and is not built yet. The Identity Workspace is the first live tool; the rest light up as the platform grows.</p>
  <a class="btn" href="/admin/anokii">Back to dashboard</a>
</div>
{% endblock %}
