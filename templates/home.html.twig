{% extends "base.html.twig" %}

{% block title %}First Nations Procurement Inc., Service &amp; Sourcing Solutions{% endblock %}

{% block content %}
<section class="hero">
  <div class="grid-bg"></div><div class="glow"></div>
  <div class="wrap">
    <p class="eyebrow">100% First Nations-owned &nbsp;&middot;&nbsp; Since 2017</p>
    <p class="pre">We can provide a solution for your operational needs.</p>
    <h1 class="display">Service &amp; Sourcing Solutions</h1>
    <p class="oneline">Indigenous-owned sourcing, technology, and protection.</p>
    <div class="cta">
      <a class="btn cyan" href="/contact">Get a free quote</a>
      <a class="btn ghost" href="/technology">Explore our solutions</a>
    </div>
    <div class="trust">
      <span><b>100%</b> First Nations-owned</span>
      <span><b>Since 2017</b> operating</span>
      <span><b>Sagamok</b> Anishnawbek</span>
    </div>
  </div>
</section>

<section id="what" class="center"><div class="wrap">
  <p class="sec-h">What we do</p>
  <h2 class="sec-t display">Three lanes, one qualification</h2>
  <p class="sec-sub">Everything we offer runs on the same foundation: a 100% First Nations-owned company qualified to deliver through Indigenous procurement channels.</p>
  <div class="lanes" style="text-align:left">
    <div class="lane">
      <svg class="ic" viewBox="0 0 40 40" fill="none"><rect x="6" y="12" width="28" height="20" rx="1.5" stroke="currentColor" stroke-width="2"/><path d="M6 18 H34" stroke="#1fb6d6" stroke-width="2"/><path d="M14 12 V8 H26 V12" stroke="currentColor" stroke-width="2"/></svg>
      <span class="tag">Running today</span>
      <h3 class="display">Sourcing &amp; Services</h3>
      <p>Indigenous-content sourcing, sampling, and trade missions. We find, vet, and deliver the goods and services your operation needs, backed by a Faraday data-protection product line in stock.</p>
    </div>
    <a class="lane lane--link" href="/technology">
      <svg class="ic" viewBox="0 0 40 40" fill="none"><rect x="7" y="9" width="26" height="18" rx="1.5" stroke="currentColor" stroke-width="2"/><path d="M14 33 H26 M20 27 V33" stroke="#1fb6d6" stroke-width="2"/><circle cx="20" cy="18" r="4" stroke="currentColor" stroke-width="2"/></svg>
      <span class="tag">Building</span>
      <h3 class="display">Technology &amp; Software</h3>
      <p>Sovereign, Nation-owned software: websites and member portals, a secure workspace, and department tools, hosted in Canada and governed by the Nation. Data that stays yours.</p>
      <span class="lane-go">Explore the platform &rarr;</span>
    </a>
    <div class="lane">
      <svg class="ic" viewBox="0 0 40 40" fill="none"><path d="M20 6 L32 11 V20 C32 28 26 33 20 35 C14 33 8 28 8 20 V11 Z" stroke="currentColor" stroke-width="2"/><circle cx="20" cy="19" r="3" fill="#1fb6d6"/></svg>
      <span class="tag">Shipping now</span>
      <h3 class="display">Privacy &amp; Protection</h3>
      <p>Counter-surveillance, data protection, and protective gear, led by our Faraday line: enclosures that shield devices and data from interception. Real products, already shipping.</p>
    </div>
  </div>
</div></section>

<section class="band"><div class="wrap"><div class="grid">
  <div>
    <p class="sec-h">Built on sovereignty</p>
    <h2 class="display">Procurement is our qualification. Sovereignty is our purpose.</h2>
    <p>FNPI exists to strengthen Indigenous economic self-determination. Our Indigenous ownership is not a label, it is the qualification that lets governments and corporations buy from us and meet their Indigenous procurement commitments, across sourcing, technology, and protection alike.</p>
    <p style="margin-top:18px"><a class="btn cyan" href="/technology">See the sovereign platform</a></p>
  </div>
  <div class="proof">
    <div class="p"><b>100%</b><span>First Nations-owned and controlled</span></div>
    <div class="p"><b>5%</b><span>Federal Indigenous procurement target we qualify for</span></div>
    <div class="p"><b>2017</b><span>Operating and delivering since</span></div>
    <div class="p"><b>10+</b><span>Years of supply-chain experience</span></div>
  </div>
</div></div></section>

<section class="faraday"><div class="wrap"><div class="grid">
  <div class="panel"><div class="g"></div><span>Faraday Protection</span></div>
  <div>
    <p class="sec-h" style="color:#7fd6e8">In stock and shipping</p>
    <h2 class="sec-t display">Faraday cases</h2>
    <p class="sec-sub">Electromagnetic-shielding enclosures that block cellular, WiFi, GPS, and radio signals to protect devices and data from interception. A tangible counter-surveillance and privacy product, available now on request.</p>
    <a class="btn cyan" href="/contact">Request Faraday cases</a>
  </div>
</div></div></section>

<section id="about" class="center"><div class="wrap">
  <p class="sec-h">About First Nations Procurement Inc.</p>
  <h2 class="sec-t display" style="margin-bottom:34px">A trusted Indigenous partner</h2>
  <div class="vm-wrap">
    <div class="vm">
      <p class="lbl">Our Vision</p>
      <p>To be a trusted leader in Indigenous engagement and strengthen national sovereignty while fostering economic sovereignty.</p>
    </div>
    <div class="vm">
      <p class="lbl">Our Mission</p>
      <p>To provide exceptional sourcing and services solutions that strengthen economic self-determination, building trusted industry relationships and a legacy of strength and opportunity for generations to come.</p>
    </div>
  </div>
</div></section>

<section id="contact" class="band center"><div class="wrap">
  <p class="sec-h">Get in touch</p>
  <h2 class="sec-t display">Tell us what your Nation needs</h2>
  <p class="sec-sub">From a single sourcing request to a Nation-wide platform, start with a free quote. We work with First Nations Councils and administrators, and with funders and partners who want to support the build.</p>
  <div class="cta" style="justify-content:center">
    <a class="btn cyan" href="/contact">Request a quote</a>
    <a class="btn" href="/technology">Explore the platform</a>
  </div>
</div></section>
{% endblock %}
