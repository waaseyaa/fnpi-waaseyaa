{# Lanes lane1..lane3 always; lane4 is optional with the same shape
   (tag/h3/body, optional href/go). A lane with an href renders as a link
   card, showing the lane-go arrow when go is also set (go without href is
   ignored: the arrow is a link affordance). Four lanes switch the grid to
   the lanes-4 layout (4 / 2 / 1 columns by viewport). #}
<section id="what" class="center"><div class="wrap">
  <p class="sec-h">{{ blk.sec_h|raw }}</p>
  <h2 class="sec-t display">{{ blk.sec_t|raw }}</h2>
  <p class="sec-sub">{{ blk.sec_sub|raw }}</p>
  <div class="lanes{{ blk.lane4 is defined ? ' lanes-4' : '' }}" style="text-align:left">
{% for key in ['lane1', 'lane2', 'lane3', 'lane4'] %}{% if blk[key] is defined %}{% set lane = blk[key] %}{% if lane.href is defined %}    <a class="lane lane--link" href="{{ lane.href }}">
{% else %}    <div class="lane">
{% endif %}{% if key == 'lane1' %}      <svg class="ic" viewBox="0 0 40 40" fill="none"><rect x="6" y="12" width="28" height="20" rx="1.5" stroke="currentColor" stroke-width="2"/><path d="M6 18 H34" stroke="#1fb6d6" stroke-width="2"/><path d="M14 12 V8 H26 V12" stroke="currentColor" stroke-width="2"/></svg>
{% elseif key == 'lane2' %}      <svg class="ic" viewBox="0 0 40 40" fill="none"><rect x="7" y="9" width="26" height="18" rx="1.5" stroke="currentColor" stroke-width="2"/><path d="M14 33 H26 M20 27 V33" stroke="#1fb6d6" stroke-width="2"/><circle cx="20" cy="18" r="4" stroke="currentColor" stroke-width="2"/></svg>
{% elseif key == 'lane3' %}      <svg class="ic" viewBox="0 0 40 40" fill="none"><path d="M20 6 L32 11 V20 C32 28 26 33 20 35 C14 33 8 28 8 20 V11 Z" stroke="currentColor" stroke-width="2"/><circle cx="20" cy="19" r="3" fill="#1fb6d6"/></svg>
{% else %}      <svg class="ic" viewBox="0 0 40 40" fill="none"><path d="M9 30 C9 22 31 23 31 15" stroke="currentColor" stroke-width="2"/><circle cx="9" cy="33" r="3" stroke="currentColor" stroke-width="2"/><circle cx="31" cy="12" r="3" stroke="currentColor" stroke-width="2"/><circle cx="20" cy="22.5" r="2.5" fill="#1fb6d6"/></svg>
{% endif %}      <span class="tag">{{ lane.tag|raw }}</span>
      <h3 class="display">{{ lane.h3|raw }}</h3>
      <p>{{ lane.body|raw }}</p>
{% if lane.href is defined and lane.go is defined %}      <span class="lane-go">{{ lane.go|raw }}</span>
{% endif %}{% if lane.href is defined %}    </a>
{% else %}    </div>
{% endif %}{% endif %}{% endfor %}  </div>
</div></section>
