{# Dark feature band: panel left, copy right. The panel renders, in order of
   preference: an HTML5 video (blk.video mp4 + optional blk.video_poster,
   native controls, no autoplay), a still image (blk.image), else the labelled
   decorative panel. blk.image_fit: 'cover' (default, fills the fixed panel,
   for product stills) or 'natural' (keeps the image aspect and grows the
   panel, with blk.panel_label as a caption below, for screenshots). #}
{% set fit = blk.image_fit|default('cover') %}
<section class="faraday"><div class="wrap"><div class="grid">
  <div class="panel{% if blk.image is defined and blk.image and fit != 'cover' %} panel-natural{% endif %}">{% if blk.video is defined and blk.video %}<video controls preload="metadata"{% if blk.video_poster is defined and blk.video_poster %} poster="{{ blk.video_poster }}"{% endif %} style="width:100%;height:100%;object-fit:cover;display:block">
      <source src="{{ blk.video }}" type="video/mp4">
    </video>{% elseif blk.image is defined and blk.image %}{% if fit == 'cover' %}<img src="{{ blk.image }}" alt="{{ blk.image_alt|default('') }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block">{% else %}<img src="{{ blk.image }}" alt="{{ blk.image_alt|default('') }}" loading="lazy">{% if blk.panel_label is defined and blk.panel_label %}<span class="panel-cap">{{ blk.panel_label|raw }}</span>{% endif %}{% endif %}{% else %}<div class="g"></div><span>{{ blk.panel_label|raw }}</span>{% endif %}</div>
  <div>
    <p class="sec-h" style="color:#7fd6e8">{{ blk.sec_h|raw }}</p>
    <h2 class="sec-t display">{{ blk.sec_t|raw }}</h2>
    <p class="sec-sub">{{ blk.sec_sub|raw }}</p>
    <a class="btn cyan" href="{{ blk.cta.href }}">{{ blk.cta.label|raw }}</a>
  </div>
</div></div></section>
